@model AudioGuideAdmin.ViewModels.Dashboard.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";

    string FormatDuration(int seconds)
    {
        if (seconds <= 0) return "0s";

        var time = TimeSpan.FromSeconds(seconds);

        if (time.TotalHours >= 1)
        {
            return $"{(int)time.TotalHours}h {time.Minutes}m";
        }

        if (time.TotalMinutes >= 1)
        {
            return $"{time.Minutes}m {time.Seconds}s";
        }

        return $"{time.Seconds}s";
    }

    var totalLanguageLogs = Model.ViLogs + Model.EnLogs;
    var viPercent = totalLanguageLogs > 0 ? Math.Round((double)Model.ViLogs / totalLanguageLogs * 100, 1) : 0;
    var enPercent = totalLanguageLogs > 0 ? Math.Round((double)Model.EnLogs / totalLanguageLogs * 100, 1) : 0;

    var totalTriggerLogs = Model.DemoLogs + Model.TourLogs;
    var demoPercent = totalTriggerLogs > 0 ? Math.Round((double)Model.DemoLogs / totalTriggerLogs * 100, 1) : 0;
    var tourPercent = totalTriggerLogs > 0 ? Math.Round((double)Model.TourLogs / totalTriggerLogs * 100, 1) : 0;
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    .dashboard-shell {
    padding-bottom: 2rem;
    }

    .dashboard-hero {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
    }

    .dashboard-title {
    font-size: 2.35rem;
    font-weight: 900;
    letter-spacing: -0.045em;
    color: #0f172a;
    margin-bottom: 0.25rem;
    }

    .dashboard-subtitle {
    color: #64748b;
    font-size: 1rem;
    margin-bottom: 0;
    }

    .dashboard-badge {
    padding: 0.55rem 0.85rem;
    border-radius: 999px;
    background: #ecfdf5;
    color: #047857;
    font-weight: 800;
    font-size: 0.86rem;
    white-space: nowrap;
    }

    .metric-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    margin-bottom: 1.25rem;
    }

    .metric-card {
    border: 1px solid #e5e7eb;
    border-radius: 1.25rem;
    background: #ffffff;
    box-shadow: 0 14px 35px rgba(15, 23, 42, 0.06);
    padding: 1.15rem;
    overflow: hidden;
    position: relative;
    }

    .metric-card::after {
    content: "";
    position: absolute;
    right: -28px;
    top: -28px;
    width: 90px;
    height: 90px;
    border-radius: 999px;
    background: rgba(15, 23, 42, 0.04);
    }

    .metric-label {
    color: #64748b;
    font-weight: 800;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.65rem;
    }

    .metric-value {
    font-size: 2.1rem;
    font-weight: 900;
    color: #0f172a;
    line-height: 1;
    letter-spacing: -0.04em;
    }

    .metric-note {
    margin-top: 0.55rem;
    color: #64748b;
    font-size: 0.88rem;
    font-weight: 600;
    }

    .panel-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 1.25rem;
    margin-bottom: 1.25rem;
    }

    .panel-card {
    border: 1px solid #e5e7eb;
    border-radius: 1.25rem;
    background: #ffffff;
    box-shadow: 0 14px 35px rgba(15, 23, 42, 0.06);
    overflow: hidden;
    height: 100%;
    }

    .panel-header {
    padding: 1rem 1.15rem;
    border-bottom: 1px solid #eef2f7;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    }

    .panel-title {
    font-weight: 900;
    color: #0f172a;
    margin: 0;
    }

    .panel-note {
    color: #64748b;
    font-size: 0.85rem;
    font-weight: 700;
    }

    .panel-body {
    padding: 1.15rem;
    }

    .chart-wrap {
    height: 280px;
    position: relative;
    }

    .health-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
    margin-top: 1rem;
    }

    .health-card {
    background: #f8fafc;
    border: 1px solid #eef2f7;
    border-radius: 1rem;
    padding: 0.9rem;
    }

    .health-label {
    color: #64748b;
    font-size: 0.82rem;
    font-weight: 800;
    margin-bottom: 0.35rem;
    }

    .health-value {
    color: #0f172a;
    font-size: 1.4rem;
    font-weight: 900;
    line-height: 1;
    }

    .progress-block {
    margin-bottom: 1rem;
    }

    .progress-head {
    display: flex;
    justify-content: space-between;
    font-weight: 800;
    font-size: 0.9rem;
    color: #334155;
    margin-bottom: 0.45rem;
    }

    .soft-progress {
    height: 0.7rem;
    background: #eef2f7;
    border-radius: 999px;
    overflow: hidden;
    }

    .soft-progress-bar {
    height: 100%;
    border-radius: 999px;
    background: #111827;
    }

    .soft-progress-bar.blue {
    background: #2563eb;
    }

    .soft-progress-bar.green {
    background: #16a34a;
    }

    .soft-progress-bar.amber {
    background: #f59e0b;
    }

    .table-card {
    border: 1px solid #e5e7eb;
    border-radius: 1.25rem;
    background: #ffffff;
    box-shadow: 0 14px 35px rgba(15, 23, 42, 0.06);
    overflow: hidden;
    }

    .playback-table th {
    color: #64748b;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
    }

    .playback-table td {
    vertical-align: middle;
    font-size: 0.92rem;
    }

    .stall-name {
    font-weight: 900;
    color: #0f172a;
    }

    .stall-meta {
    color: #64748b;
    font-size: 0.82rem;
    line-height: 1.45;
    }

    .leaderboard-item {
    display: flex;
    gap: 0.85rem;
    padding: 0.95rem 1.15rem;
    border-bottom: 1px solid #eef2f7;
    }

    .leaderboard-item:last-child {
    border-bottom: none;
    }

    .leaderboard-rank {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 999px;
    background: #0f172a;
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 900;
    flex-shrink: 0;
    }

    .leaderboard-main {
    flex: 1;
    min-width: 0;
    }

    .leaderboard-name {
    font-weight: 900;
    color: #0f172a;
    line-height: 1.35;
    }

    .leaderboard-meta {
    color: #64748b;
    font-size: 0.84rem;
    line-height: 1.45;
    }

    .leaderboard-count {
    text-align: right;
    flex-shrink: 0;
    }

    .leaderboard-count-value {
    font-weight: 900;
    color: #0f172a;
    font-size: 1.05rem;
    }

    .leaderboard-count-label {
    color: #64748b;
    font-size: 0.78rem;
    }

    .empty-panel {
    color: #64748b;
    padding: 2rem 1rem;
    text-align: center;
    }

    @@media (max-width: 1199.98px) {
    .metric-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .panel-grid {
    grid-template-columns: 1fr;
    }
    }

    @@media (max-width: 767.98px) {
    .dashboard-hero {
    align-items: flex-start;
    flex-direction: column;
    }

    .dashboard-title {
    font-size: 1.9rem;
    }

    .metric-grid {
    grid-template-columns: 1fr;
    }

    .health-row {
    grid-template-columns: 1fr;
    }
    }
</style>

<div class="dashboard-shell">
    <div class="dashboard-hero">
        <div>
            <h1 class="dashboard-title">Analytics Dashboard</h1>
            <p class="dashboard-subtitle">
                Operational overview for Audio Guide Phố Ẩm Thực Vĩnh Khánh.
            </p>
        </div>

        <div class="dashboard-badge">
            Live dashboard
        </div>
    </div>

    <div class="metric-grid">
        <div class="metric-card">
            <div class="metric-label">Web visits</div>
            <div class="metric-value">@Model.TotalWebVisits</div>
            <div class="metric-note">@Model.ActiveWebUsers active users now</div>
        </div>

        <div class="metric-card">
            <div class="metric-label">Playback sessions</div>
            <div class="metric-value">@Model.TotalPlaybackLogs</div>
            <div class="metric-note">@Model.CompletedLogs completed sessions</div>
        </div>

        <div class="metric-card">
            <div class="metric-label">Actual listening</div>
            <div class="metric-value">@FormatDuration(Model.TotalActualListeningSeconds)</div>
            <div class="metric-note">Average @FormatDuration(Model.AverageListeningSeconds)</div>
        </div>

        <div class="metric-card">
            <div class="metric-label">Completion rate</div>
            <div class="metric-value">@Model.CompletionRatePercent%</div>
            <div class="metric-note">Completed / all playback sessions</div>
        </div>
    </div>

    <div class="panel-grid">
        <div class="panel-card">
            <div class="panel-header">
                <h2 class="panel-title">Playback Health</h2>
                <span class="panel-note">Completed, stopped, interrupted</span>
            </div>

            <div class="panel-body">
                <div class="chart-wrap">
                    <canvas id="playbackStatusChart"></canvas>
                </div>

                <div class="health-row">
                    <div class="health-card">
                        <div class="health-label">Completed</div>
                        <div class="health-value">@Model.CompletedLogs</div>
                    </div>

                    <div class="health-card">
                        <div class="health-label">Stopped</div>
                        <div class="health-value">@Model.StoppedLogs</div>
                    </div>

                    <div class="health-card">
                        <div class="health-label">Interrupted</div>
                        <div class="health-value">@Model.InterruptedLogs</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="panel-card">
            <div class="panel-header">
                <h2 class="panel-title">Distribution</h2>
                <span class="panel-note">Language and trigger type</span>
            </div>

            <div class="panel-body">
                <div class="progress-block">
                    <div class="progress-head">
                        <span>Vietnamese sessions</span>
                        <span>@viPercent%</span>
                    </div>
                    <div class="soft-progress">
                        <div class="soft-progress-bar blue" style="width:@viPercent%"></div>
                    </div>
                </div>

                <div class="progress-block">
                    <div class="progress-head">
                        <span>English sessions</span>
                        <span>@enPercent%</span>
                    </div>
                    <div class="soft-progress">
                        <div class="soft-progress-bar" style="width:@enPercent%"></div>
                    </div>
                </div>

                <hr />

                <div class="progress-block">
                    <div class="progress-head">
                        <span>Demo sessions</span>
                        <span>@demoPercent%</span>
                    </div>
                    <div class="soft-progress">
                        <div class="soft-progress-bar amber" style="width:@demoPercent%"></div>
                    </div>
                </div>

                <div class="progress-block">
                    <div class="progress-head">
                        <span>Tour sessions</span>
                        <span>@tourPercent%</span>
                    </div>
                    <div class="soft-progress">
                        <div class="soft-progress-bar green" style="width:@tourPercent%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="panel-grid">
        <div class="table-card">
            <div class="panel-header">
                <h2 class="panel-title">Recent Playback Sessions</h2>
                <span class="panel-note">Latest 5 records</span>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 playback-table">
                    <thead class="table-light">
                        <tr>
                            <th>Id</th>
                            <th>Food Stall</th>
                            <th>Lang</th>
                            <th>Trigger</th>
                            <th>Status</th>
                            <th>Started</th>
                            <th>Actual</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.RecentPlaybackLogs.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">
                                    No playback logs found.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model.RecentPlaybackLogs)
                            {
                                <tr>
                                    <td class="fw-bold">#@item.Id</td>
                                    <td>
                                        <div class="stall-name">@item.FoodStallName</div>
                                        <div class="stall-meta">@item.FoodStallAddress</div>
                                        <div class="stall-meta">Stall ID: @item.FoodStallId</div>
                                    </td>
                                    <td>
                                        @if (item.LanguageCode == "vi")
                                        {
                                            <span class="badge rounded-pill bg-primary">VI</span>
                                        }
                                        else if (item.LanguageCode == "en")
                                        {
                                            <span class="badge rounded-pill bg-secondary">EN</span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-light text-dark">@item.LanguageCode</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge rounded-pill bg-light text-dark">@item.TriggerType</span>
                                    </td>
                                    <td>
                                        @if (item.Status == "Completed")
                                        {
                                            <span class="badge rounded-pill bg-success">@item.Status</span>
                                        }
                                        else if (item.Status == "Stopped")
                                        {
                                            <span class="badge rounded-pill bg-warning text-dark">@item.Status</span>
                                        }
                                        else if (item.Status == "Interrupted")
                                        {
                                            <span class="badge rounded-pill bg-danger">@item.Status</span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-secondary">@item.Status</span>
                                        }
                                    </td>
                                    <td>@item.StartedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@FormatDuration(item.ActualDurationSeconds)</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="panel-card">
            <div class="panel-header">
                <h2 class="panel-title">Top Food Stalls</h2>
                <span class="panel-note">By completed playback</span>
            </div>

            @if (!Model.TopFoodStalls.Any())
            {
                <div class="empty-panel">
                    No playback data found.
                </div>
            }
            else
            {
                @for (int i = 0; i < Model.TopFoodStalls.Count; i++)
                {
                    var item = Model.TopFoodStalls[i];

                    <div class="leaderboard-item">
                        <div class="leaderboard-rank">@(i + 1)</div>

                        <div class="leaderboard-main">
                            <div class="leaderboard-name">@item.FoodStallName</div>
                            <div class="leaderboard-meta">@item.FoodStallAddress</div>
                            <div class="leaderboard-meta">Stall ID: @item.FoodStallId</div>
                        </div>

                        <div class="leaderboard-count">
                            <div class="leaderboard-count-value">@item.PlaybackCount</div>
                            <div class="leaderboard-count-label">plays</div>
                            <div class="leaderboard-count-label">@FormatDuration(item.TotalActualDurationSeconds)</div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
        const statusCanvas = document.getElementById("playbackStatusChart");
        if (!statusCanvas) return;

        new Chart(statusCanvas, {
        type: "doughnut",
        data: {
        labels: ["Completed", "Stopped", "Interrupted"],
        datasets: [{
        data: [
        @Model.CompletedLogs,
        @Model.StoppedLogs,
        @Model.InterruptedLogs
        ],
        backgroundColor: [
        "#16a34a",
        "#f59e0b",
        "#dc2626"
        ],
        borderColor: "#ffffff",
        borderWidth: 4,
        hoverOffset: 8
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: "68%",
        plugins: {
        legend: {
        position: "bottom",
        labels: {
        usePointStyle: true,
        boxWidth: 8,
        font: {
        weight: "700"
        }
        }
        },
        tooltip: {
        callbacks: {
        label: function (context) {
        return `${context.label}: ${context.raw}`;
        }
        }
        }
        }
        }
        });
        })();
    </script>
}