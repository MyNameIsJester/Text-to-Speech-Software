@model AudioGuideAdmin.ViewModels.Auth.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Login</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body class="d-flex justify-content-center align-items-center vh-100 bg-light">

    <div class="card p-4" style="width:350px;">
        <h3 class="mb-3">Login</h3>

        <form asp-action="Login" method="post">
            <input asp-for="Email" class="form-control mb-2" placeholder="Email" />
            <input asp-for="Password" class="form-control mb-2" placeholder="Password" />

            <button type="submit" class="btn btn-dark w-100">Login</button>
        </form>

        <div class="mt-3 small text-muted">
            admin@audioguide.local / admin123
        </div>
    </div>

</body>
</html>