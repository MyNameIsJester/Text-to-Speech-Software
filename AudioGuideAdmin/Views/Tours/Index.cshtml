@model IEnumerable<AudioGuideAPI.Models.Tour>

@{
    ViewData["Title"] = "Tours";
    var isAdmin = User.IsInRole("Admin");
    var search = ViewBag.Search as string ?? "";
}

<style>
    .page-subtitle {
        color: #6c757d;
        margin-bottom: 0;
    }

    .filter-card,
    .content-card {
        border: none;
        border-radius: 1rem;
        box-shadow: 0 0.125rem 0.5rem rgba(0,0,0,0.06);
    }

    .tour-table th {
        white-space: nowrap;
        font-size: 0.92rem;
    }

    .tour-table td {
        vertical-align: top;
        padding-top: 0.95rem;
        padding-bottom: 0.95rem;
    }

    .tour-row-link {
        cursor: pointer;
        transition: background-color 0.15s ease;
    }

        .tour-row-link:hover {
            background-color: #f8f9fa;
        }

    .id-cell {
        font-weight: 700;
        color: #212529;
        white-space: nowrap;
    }

    .lang-badge {
        font-size: 0.72rem;
        font-weight: 700;
        border-radius: 999px;
        padding: 0.25rem 0.55rem;
        display: inline-block;
        margin-bottom: 0.45rem;
    }

    .lang-vi {
        background: #e7f1ff;
        color: #0d6efd;
    }

    .lang-en {
        background: #f3f4f6;
        color: #495057;
    }

    .tour-name {
        font-weight: 700;
        font-size: 1rem;
        color: #212529;
        margin-bottom: 0.35rem;
        line-height: 1.35;
    }

    .tour-desc {
        color: #6c757d;
        font-size: 0.88rem;
        line-height: 1.4;
        margin-bottom: 0.35rem;
    }

    .tour-hint {
        font-size: 0.82rem;
        color: #6c757d;
        font-style: italic;
    }

    .stop-count-box {
        display: inline-flex;
        min-width: 2.2rem;
        height: 2.2rem;
        border-radius: 999px;
        align-items: center;
        justify-content: center;
        background: #212529;
        color: #fff;
        font-weight: 700;
        font-size: 0.95rem;
    }

    .stop-count-label {
        margin-top: 0.35rem;
        font-size: 0.82rem;
        color: #6c757d;
    }

    .action-stack {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
    }

    .empty-state {
        padding: 3rem 1rem;
        text-align: center;
        color: #6c757d;
    }

    .empty-state-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #343a40;
        margin-bottom: 0.35rem;
    }

    .search-label {
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 0.4rem;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Tours</h2>
        <p class="page-subtitle">Browse guided routes and preview each route on the map.</p>
    </div>

    @if (isAdmin)
    {
        <a asp-action="Create" class="btn btn-success">Create Tour</a>
    }
</div>

<div class="card filter-card mb-4">
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row g-3 align-items-end">
                <div class="col-lg-8">
                    <label class="search-label" for="search">Search Tour</label>
                    <input type="text"
                           id="search"
                           name="search"
                           value="@search"
                           class="form-control"
                           placeholder="Search by Vietnamese or English tour name, or description..." />
                </div>

                <div class="col-lg-4">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Apply</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card content-card">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-state-title">No tours found</div>
                <div>Try a different keyword or create a new tour.</div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 tour-table">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 70px;">Id</th>
                            <th style="min-width: 280px;">Vietnamese</th>
                            <th style="min-width: 280px;">English</th>
                            <th style="width: 120px;">Stops</th>
                            <th style="width: 110px;">Status</th>
                            @if (isAdmin)
                            {
                                <th style="min-width: 190px;">Actions</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var vi = item.Translations.FirstOrDefault(t => t.Language.LanguageCode == "vi");
                            var en = item.Translations.FirstOrDefault(t => t.Language.LanguageCode == "en");
                            var detailsUrl = Url.Action("Details", "Tours", new { id = item.Id });

                            <tr class="tour-row-link" onclick="window.location='@detailsUrl'">
                                <td class="id-cell">@item.Id</td>

                                <td>
                                    <div class="lang-badge lang-vi">VI</div>
                                    <div class="tour-name">@(vi?.Name ?? "-")</div>
                                    <p class="tour-desc">@(string.IsNullOrWhiteSpace(vi?.Description) ? "No Vietnamese description" : vi!.Description)</p>
                                    <div class="tour-hint">Click row to preview route on map.</div>
                                </td>

                                <td>
                                    <div class="lang-badge lang-en">EN</div>
                                    <div class="tour-name">@(en?.Name ?? "-")</div>
                                    <p class="tour-desc">@(string.IsNullOrWhiteSpace(en?.Description) ? "No English description" : en!.Description)</p>
                                    <div class="tour-hint">Click row to preview route on map.</div>
                                </td>

                                <td>
                                    <div class="stop-count-box">@item.TourItems.Count</div>
                                    <div class="stop-count-label">Stops</div>
                                </td>

                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>

                                @if (isAdmin)
                                {
                                    <td onclick="event.stopPropagation();">
                                        <div class="action-stack">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">
                                                Edit
                                            </a>

                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                                Delete
                                            </a>
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>