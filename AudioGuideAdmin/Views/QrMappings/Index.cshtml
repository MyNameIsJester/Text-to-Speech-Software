@model IEnumerable<AudioGuideAPI.Models.QrMapping>

@{
    ViewData["Title"] = "QR Mappings";
}

<style>
    .page-subtitle {
        color: #6c757d;
        margin-bottom: 0;
    }

    .content-card {
        border: none;
        border-radius: 1rem;
        box-shadow: 0 0.125rem 0.5rem rgba(0,0,0,0.06);
    }

    .qr-table th {
        white-space: nowrap;
        font-size: 0.92rem;
    }

    .qr-table td {
        vertical-align: top;
        padding-top: 0.95rem;
        padding-bottom: 0.95rem;
    }

    .id-cell {
        font-weight: 700;
        color: #212529;
        white-space: nowrap;
    }

    .code-pill {
        display: inline-block;
        font-family: monospace;
        font-size: 0.95rem;
        font-weight: 700;
        background: #f8f9fa;
        color: #212529;
        border: 1px solid #dee2e6;
        border-radius: 0.75rem;
        padding: 0.45rem 0.7rem;
    }

    .stall-meta {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
    }

    .stall-title {
        font-weight: 600;
        color: #212529;
    }

    .stall-subtitle {
        color: #6c757d;
        font-size: 0.88rem;
        line-height: 1.35;
    }

    .action-stack {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
    }

    .empty-state {
        padding: 3rem 1rem;
        text-align: center;
        color: #6c757d;
    }

    .empty-state-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #343a40;
        margin-bottom: 0.35rem;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">QR Mappings</h2>
        <p class="page-subtitle">Manage QR codes and map them to food stalls.</p>
    </div>

    <a asp-action="Create" class="btn btn-success">Create QR Mapping</a>
</div>

<div class="card content-card">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-state-title">No QR mappings found</div>
                <div>Create a new QR mapping to connect a QR code value to a food stall.</div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 qr-table">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 70px;">Id</th>
                            <th style="width: 110px;">Stall Id</th>
                            <th style="min-width: 280px;">Food Stall</th>
                            <th style="min-width: 220px;">Code Value</th>
                            <th style="width: 110px;">Status</th>
                            <th style="min-width: 180px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="id-cell">@item.Id</td>

                                <td class="id-cell">@item.FoodStallId</td>

                                <td>
                                    <div class="stall-meta">
                                        <div class="stall-title">Food Stall #@item.FoodStallId</div>
                                        <div class="stall-subtitle">
                                            @(string.IsNullOrWhiteSpace(item.FoodStall?.Address)
                                                ? "No address"
                                                : item.FoodStall.Address)
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    <span class="code-pill">@item.CodeValue</span>
                                </td>

                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>

                                <td>
                                    <div class="action-stack">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">
                                            Edit
                                        </a>

                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                            Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>