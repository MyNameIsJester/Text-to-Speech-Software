@model IEnumerable<AudioGuideAPI.Models.PlaybackLog>

@{
    ViewData["Title"] = "Playback Logs";

    var languageCode = ViewBag.LanguageCode as string ?? "";
    var triggerType = ViewBag.TriggerType as string ?? "";
    var status = ViewBag.Status as string ?? "";
    var foodStallKeyword = ViewBag.FoodStallKeyword as string ?? "";

    var totalLogs = ViewBag.TotalLogs as int? ?? 0;
    var viLogs = ViewBag.ViLogs as int? ?? 0;
    var enLogs = ViewBag.EnLogs as int? ?? 0;
    var completedLogs = ViewBag.CompletedLogs as int? ?? 0;
    var stoppedLogs = ViewBag.StoppedLogs as int? ?? 0;
    var interruptedLogs = ViewBag.InterruptedLogs as int? ?? 0;
}

<style>
    .page-subtitle {
        color: #6c757d;
        margin-bottom: 0;
    }

    .metric-card,
    .filter-card,
    .content-card {
        border: none;
        border-radius: 1rem;
        box-shadow: 0 0.125rem 0.5rem rgba(0,0,0,0.06);
    }

    .metric-label {
        font-size: 0.85rem;
        color: #6c757d;
        margin-bottom: 0.35rem;
    }

    .metric-value {
        font-size: 1.7rem;
        font-weight: 700;
        line-height: 1.1;
        color: #212529;
    }

    .filter-label {
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 0.4rem;
    }

    .log-table th {
        white-space: nowrap;
        font-size: 0.92rem;
    }

    .log-table td {
        vertical-align: middle;
    }

    .stall-name {
        font-weight: 600;
        color: #212529;
        margin-bottom: 0.15rem;
    }

    .meta-line {
        color: #6c757d;
        font-size: 0.88rem;
        line-height: 1.35;
    }

    .empty-state {
        padding: 3rem 1rem;
        text-align: center;
        color: #6c757d;
    }

    .empty-state-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #343a40;
        margin-bottom: 0.35rem;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Playback Logs</h2>
        <p class="page-subtitle">Track playback sessions, status, and actual listening duration.</p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-2">
        <div class="card metric-card">
            <div class="card-body">
                <div class="metric-label">Total</div>
                <div class="metric-value">@totalLogs</div>
            </div>
        </div>
    </div>

    <div class="col-md-2">
        <div class="card metric-card">
            <div class="card-body">
                <div class="metric-label">VI</div>
                <div class="metric-value">@viLogs</div>
            </div>
        </div>
    </div>

    <div class="col-md-2">
        <div class="card metric-card">
            <div class="card-body">
                <div class="metric-label">EN</div>
                <div class="metric-value">@enLogs</div>
            </div>
        </div>
    </div>

    <div class="col-md-2">
        <div class="card metric-card">
            <div class="card-body">
                <div class="metric-label">Completed</div>
                <div class="metric-value">@completedLogs</div>
            </div>
        </div>
    </div>

    <div class="col-md-2">
        <div class="card metric-card">
            <div class="card-body">
                <div class="metric-label">Stopped</div>
                <div class="metric-value">@stoppedLogs</div>
            </div>
        </div>
    </div>

    <div class="col-md-2">
        <div class="card metric-card">
            <div class="card-body">
                <div class="metric-label">Interrupted</div>
                <div class="metric-value">@interruptedLogs</div>
            </div>
        </div>
    </div>
</div>

<div class="card filter-card mb-4">
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row g-3 align-items-end">
                <div class="col-lg-4">
                    <label class="filter-label" for="foodStallKeyword">Food Stall</label>
                    <input type="text"
                           id="foodStallKeyword"
                           name="foodStallKeyword"
                           value="@foodStallKeyword"
                           class="form-control"
                           placeholder="Search by stall name or address..." />
                </div>

                <div class="col-lg-2">
                    <label class="filter-label" for="languageCode">Language</label>
                    <select id="languageCode" name="languageCode" class="form-select">
                        <option value="">All</option>
                        <option value="vi" selected="@(languageCode == "vi")">VI</option>
                        <option value="en" selected="@(languageCode == "en")">EN</option>
                    </select>
                </div>

                <div class="col-lg-2">
                    <label class="filter-label" for="triggerType">Trigger</label>
                    <select id="triggerType" name="triggerType" class="form-select">
                        <option value="">All</option>
                        <option value="GPS" selected="@(triggerType == "GPS")">GPS</option>
                        <option value="DEMO" selected="@(triggerType == "DEMO")">DEMO</option>
                        <option value="TOUR" selected="@(triggerType == "TOUR")">TOUR</option>
                    </select>
                </div>

                <div class="col-lg-2">
                    <label class="filter-label" for="status">Status</label>
                    <select id="status" name="status" class="form-select">
                        <option value="">All</option>
                        <option value="Started" selected="@(status == "Started")">Started</option>
                        <option value="Completed" selected="@(status == "Completed")">Completed</option>
                        <option value="Stopped" selected="@(status == "Stopped")">Stopped</option>
                        <option value="Interrupted" selected="@(status == "Interrupted")">Interrupted</option>
                    </select>
                </div>

                <div class="col-lg-2">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Apply</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card content-card">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-state-title">No playback logs found</div>
                <div>Try changing the filter or wait for new playback activity.</div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 log-table">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 70px;">Id</th>
                            <th style="min-width: 260px;">Food Stall</th>
                            <th style="width: 90px;">Lang</th>
                            <th style="width: 100px;">Trigger</th>
                            <th style="width: 120px;">Status</th>
                            <th style="width: 170px;">Started</th>
                            <th style="width: 170px;">Ended</th>
                            <th style="width: 130px;">Actual</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var viName = item.FoodStall?.Translations?.FirstOrDefault(t => t.Language?.LanguageCode == "vi")?.Name;
                            var enName = item.FoodStall?.Translations?.FirstOrDefault(t => t.Language?.LanguageCode == "en")?.Name;
                            var displayName = !string.IsNullOrWhiteSpace(viName)
                                ? viName
                                : !string.IsNullOrWhiteSpace(enName)
                                    ? enName
                                    : $"Food Stall #{item.FoodStallId}";

                            <tr>
                                <td class="fw-semibold">@item.Id</td>

                                <td>
                                    <div class="stall-name">@displayName</div>
                                    <div class="meta-line">
                                        @(string.IsNullOrWhiteSpace(item.FoodStall?.Address) ? "No address" : item.FoodStall.Address)
                                    </div>
                                </td>

                                <td>
                                    @if (item.LanguageCode == "vi")
                                    {
                                        <span class="badge bg-primary">VI</span>
                                    }
                                    else if (item.LanguageCode == "en")
                                    {
                                        <span class="badge bg-secondary">EN</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-dark">@item.LanguageCode</span>
                                    }
                                </td>

                                <td>@item.TriggerType</td>
                                <td>@item.Status</td>
                                <td>@item.StartedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</td>
                                <td>@(item.EndedAt.HasValue? item.EndedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss") : "-")</td>
                                <td>@item.ActualDurationSeconds sec</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>