@model IEnumerable<AudioGuideAPI.Models.FoodStall>

@{
    ViewData["Title"] = "Food Stalls";

    var isAdmin = User.IsInRole("Admin");
    var search = Context.Request.Query["search"].ToString();
    var status = Context.Request.Query["status"].ToString();
}

<style>
    .page-subtitle {
        color: #6c757d;
        margin-bottom: 0;
    }

    .filter-card,
    .content-card {
        border: none;
        border-radius: 1rem;
        box-shadow: 0 0.125rem 0.5rem rgba(0,0,0,0.06);
    }

    .filter-label {
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 0.4rem;
    }

    .stall-table th {
        white-space: nowrap;
        font-size: 0.92rem;
    }

    .stall-table td {
        vertical-align: top;
        padding-top: 0.95rem;
        padding-bottom: 0.95rem;
    }

    .stall-name {
        font-weight: 700;
        font-size: 1rem;
        color: #212529;
        margin-bottom: 0.35rem;
        line-height: 1.35;
    }

    .lang-badge {
        font-size: 0.72rem;
        font-weight: 700;
        border-radius: 999px;
        padding: 0.25rem 0.55rem;
        display: inline-block;
        margin-bottom: 0.45rem;
    }

    .lang-vi {
        background: #e7f1ff;
        color: #0d6efd;
    }

    .lang-en {
        background: #f3f4f6;
        color: #495057;
    }

    .meta-line {
        display: flex;
        align-items: flex-start;
        gap: 0.4rem;
        color: #6c757d;
        font-size: 0.88rem;
        line-height: 1.35;
        margin-bottom: 0.2rem;
    }

    .meta-icon {
        flex-shrink: 0;
        width: 1rem;
        text-align: center;
        opacity: 0.85;
    }

    .coord-text {
        font-family: monospace;
        font-size: 0.92rem;
        color: #212529;
        white-space: nowrap;
    }

    .action-stack {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
    }

    .empty-state {
        padding: 3rem 1rem;
        text-align: center;
        color: #6c757d;
    }

    .empty-state-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #343a40;
        margin-bottom: 0.35rem;
    }

    .id-cell {
        font-weight: 700;
        color: #212529;
        white-space: nowrap;
    }

    .stall-note {
        font-size: 0.82rem;
        color: #6c757d;
        font-style: italic;
        margin-top: 0.35rem;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Food Stalls</h2>
        <p class="page-subtitle">
            @(isAdmin
                ? "Manage POIs, geofence data, and multilingual content."
                : "Browse POIs, geofence data, and multilingual content.")
        </p>
    </div>

    @if (isAdmin)
    {
        <a asp-action="Create" class="btn btn-success">
            Create New Food Stall
        </a>
    }
</div>

<div class="card filter-card mb-4">
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row g-3 align-items-end">
                <div class="col-lg-6">
                    <label class="filter-label" for="search">Search</label>
                    <input type="text"
                           id="search"
                           name="search"
                           value="@search"
                           class="form-control"
                           placeholder="Search by Vietnamese name, English name, or address..." />
                </div>

                <div class="col-lg-3">
                    <label class="filter-label" for="status">Status</label>
                    <select id="status" name="status" class="form-select">
                        <option value="" selected="@(string.IsNullOrWhiteSpace(status))">All</option>
                        <option value="active" selected="@(status == "active")">Active</option>
                        <option value="inactive" selected="@(status == "inactive")">Inactive</option>
                    </select>
                </div>

                <div class="col-lg-3">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Apply</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card content-card">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-state-title">No food stalls found</div>
                <div>Try changing the search keyword or filter.</div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 stall-table">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 70px;">Id</th>
                            <th style="min-width: 260px;">Vietnamese</th>
                            <th style="min-width: 260px;">English</th>
                            <th style="width: 120px;">Latitude</th>
                            <th style="width: 120px;">Longitude</th>
                            <th style="width: 90px;">Radius</th>
                            <th style="width: 90px;">Priority</th>
                            <th style="width: 110px;">Status</th>
                            @if (isAdmin)
                            {
                                <th style="min-width: 220px;">Actions</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var vi = item.Translations.FirstOrDefault(t => t.Language?.LanguageCode == "vi");
                            var en = item.Translations.FirstOrDefault(t => t.Language?.LanguageCode == "en");

                            <tr>
                                <td class="id-cell">@item.Id</td>

                                <td>
                                    <div class="lang-badge lang-vi">VI</div>
                                    <div class="stall-name">@(vi?.Name ?? "-")</div>

                                    <div class="meta-line">
                                        <span class="meta-icon">📍</span>
                                        <span>@(string.IsNullOrWhiteSpace(item.Address) ? "No address" : item.Address)</span>
                                    </div>
                                </td>

                                <td>
                                    <div class="lang-badge lang-en">EN</div>
                                    <div class="stall-name">@(en?.Name ?? "-")</div>

                                    <div class="meta-line">
                                        <span class="meta-icon">💰</span>
                                        <span>@(string.IsNullOrWhiteSpace(item.PriceRange) ? "No price range" : item.PriceRange)</span>
                                    </div>
                                </td>

                                <td class="coord-text">@item.Latitude</td>
                                <td class="coord-text">@item.Longitude</td>
                                <td>@item.Radius</td>
                                <td>@item.Priority</td>

                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>

                                @if (isAdmin)
                                {
                                    <td>
                                        <div class="action-stack">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">
                                                Edit Base
                                            </a>

                                            <a asp-action="EditTranslations" asp-route-id="@item.Id" class="btn btn-sm btn-warning text-dark">
                                                Translations
                                            </a>

                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                                Delete
                                            </a>
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>