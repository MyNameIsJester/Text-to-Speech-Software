@model IEnumerable<AudioGuideAPI.Models.FoodStall>

@{
    ViewData["Title"] = "Food Stalls";
    var searchTerm = ViewBag.SearchTerm as string ?? "";
    var statusFilter = ViewBag.StatusFilter as string ?? "all";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Food Stalls</h2>
        <p class="text-muted mb-0">Manage POIs, geofence data, and translations.</p>
    </div>
    <a asp-action="Create" class="btn btn-success">Create New Food Stall</a>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form method="get" asp-action="Index" class="row g-3 align-items-end">
            <div class="col-md-6">
                <label for="searchTerm" class="form-label">Search</label>
                <input type="text"
                       id="searchTerm"
                       name="searchTerm"
                       value="@searchTerm"
                       class="form-control"
                       placeholder="Search by name or address..." />
            </div>

            <div class="col-md-3">
                <label for="statusFilter" class="form-label">Status</label>
                <select id="statusFilter" name="statusFilter" class="form-select">
                    <option value="all" selected="@(statusFilter == "all")">All</option>
                    <option value="active" selected="@(statusFilter == "active")">Active</option>
                    <option value="inactive" selected="@(statusFilter == "inactive")">Inactive</option>
                </select>
            </div>

            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Apply</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-bordered align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 70px;">Id</th>
                        <th>Name (VI)</th>
                        <th>Name (EN)</th>
                        <th>Latitude</th>
                        <th>Longitude</th>
                        <th>Radius</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th style="width: 260px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">
                                No food stalls found.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            var vi = item.Translations.FirstOrDefault(t => t.Language.LanguageCode == "vi");
                            var en = item.Translations.FirstOrDefault(t => t.Language.LanguageCode == "en");

                            <tr>
                                <td>@item.Id</td>
                                <td>@(vi?.Name ?? "-")</td>
                                <td>@(en?.Name ?? "-")</td>
                                <td>@item.Latitude</td>
                                <td>@item.Longitude</td>
                                <td>@item.Radius</td>
                                <td>@item.Priority</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex flex-wrap gap-2">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Edit Base</a>
                                        <a asp-action="EditTranslations" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Translations</a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>