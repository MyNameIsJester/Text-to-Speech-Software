@model AudioGuideAdmin.ViewModels.Users.CreateUserViewModel

@{
    ViewData["Title"] = "Create User";
    var roleOptions = ViewBag.RoleOptions as IEnumerable<string> ?? Enumerable.Empty<string>();
}

<style>
    .page-subtitle {
        color: #6c757d;
        margin-bottom: 0;
    }

    .form-card {
        border: none;
        border-radius: 1rem;
        box-shadow: 0 0.125rem 0.5rem rgba(0,0,0,0.06);
        overflow: hidden;
    }

        .form-card .card-header {
            background: #fff;
            border-bottom: 1px solid #e9ecef;
            padding: 1rem 1.25rem;
            font-weight: 600;
        }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">Create User</h2>
        <p class="page-subtitle">Create a new admin or food stall owner account.</p>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="card form-card">
    <div class="card-header">
        User Information
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="FullName" class="form-label fw-semibold"></label>
                    <input asp-for="FullName" class="form-control" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="RoleName" class="form-label fw-semibold"></label>
                    <select asp-for="RoleName" class="form-select">
                        <option value="">-- Select role --</option>
                        @foreach (var role in roleOptions)
                        {
                            <option value="@role">@role</option>
                        }
                    </select>
                    <span asp-validation-for="RoleName" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Email" class="form-label fw-semibold"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Password" class="form-label fw-semibold"></label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-success">Create User</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}