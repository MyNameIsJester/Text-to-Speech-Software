@model AudioGuideWeb.Models.HomeIndexViewModel

@{
    var currentLang = Context.Request.Query["lang"].FirstOrDefault() ?? Model.CurrentLanguage ?? "vi";
    var currentVoiceLang = Context.Request.Query["voiceLang"].FirstOrDefault() ?? currentLang;
    var isEnglish = currentLang == "en";

    string T(string vi, string en) => isEnglish ? en : vi;

    ViewData["Title"] = T("Khám phá", "Explore");
    var ui = new
    {
        exploreTitle = T("Khám phá phố ẩm thực Vĩnh Khánh", "Explore Vinh Khanh Food Street"),
        exploreSubtitle = T(
            "Xem các quán ăn nổi bật trên bản đồ và mô phỏng vị trí trực tiếp để nghe phần giới thiệu phù hợp.",
            "View featured food stalls on the map and simulate your position to hear the matching narration."
        ),
        toolbarHint = T(
            "Chạm trực tiếp lên bản đồ để xác định vị trí và kích hoạt thuyết minh.",
            "Tap directly on the map to set your position and trigger narration."
        ),
        tourMode = T("Chế độ Tour", "Tour mode"),
        exploreMode = T("Chế độ Khám phá", "Explore mode"),
        noNarration = T("Chưa phát thuyết minh", "No narration playing"),
        tourReady = T("Sẵn sàng mô phỏng hành trình trên bản đồ.", "Ready to simulate the tour on the map."),
        noSimulatedPosition = T("Chưa có vị trí mô phỏng nào được chọn.", "No simulated position has been selected."),
        nextStop = T("Chặng tiếp theo", "Next stop"),
        progress = T("Tiến độ", "Progress"),
        completedTour = T("Đã hoàn tất hành trình.", "The tour has been completed."),
        finishedStop = T("Đã xong chặng này.", "This stop is completed."),
        nextIs = T("Tiếp theo là", "Next is"),
        currentNearest = T("Vị trí hiện tại gần nhất với", "Your current position is closest to"),
        outsideTour = T("không thuộc hành trình hiện tại.", "is not part of the current tour."),
        wrongStopPrefix = T("Bạn đang ở", "You are at"),
        wrongStopMiddle = T("nhưng chặng hiện tại là", "but the current stop is"),
        stillNear = T("Bạn vẫn đang ở gần", "You are still near"),
        notReplay = T("nên nội dung chưa phát lại.", "so the narration has not replayed yet."),
        playingAt = T("Đang phát nội dung tại", "Playing narration at"),
        playingPlace = T("Đang phát nội dung cho địa điểm này.", "Playing narration for this place."),
        noContentStop = T("Điểm dừng này hiện chưa có nội dung để phát.", "This stop does not have narration content yet."),
        noContentPlace = T("Quán này hiện chưa có nội dung để phát.", "This place does not have narration content yet."),
        cannotStartStop = T("Không thể bắt đầu nội dung cho điểm dừng này.", "Cannot start narration for this stop."),
        cannotStartPlace = T("Không thể bắt đầu nội dung cho địa điểm này.", "Cannot start narration for this place."),
        showOnMap = T("Đang hiển thị quán này trên bản đồ web.", "Showing this stall on the web map."),
        details = T("Xem chi tiết", "Details"),
        openMap = T("Mở bản đồ", "Open map"),
        noAddress = T("Chưa có địa chỉ", "No address available"),
        inTourStop = T("Thuộc hành trình • chặng", "In tour • stop"),
        nextButton = T("Tới chặng tiếp theo", "Go to next stop"),
        stillListen = T("Vẫn nghe", "Listen anyway"),
        backToExplore = T("Quay lại chế độ Khám phá", "Back to Explore mode"),
        simulatedPosition = T("Vị trí mô phỏng hiện tại", "Current simulated position"),
        distanceFromYou = T("Cách bạn", "Distance from you"),
        remaining = T("Còn", "Remaining"),
        stop = T("Chặng", "Stop"),
        stopFallback = T("Điểm dừng", "Stop")
    };
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
      crossorigin="" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>
    html, body, button, input, select, textarea {
        font-family: "Be Vietnam Pro", Arial, Helvetica, sans-serif;
    }

    .explore-hero {
        margin-bottom: 1rem;
    }

    .explore-title {
        font-size: 2.45rem;
        font-weight: 800;
        letter-spacing: -0.035em;
        line-height: 1.04;
        margin-bottom: 0.55rem;
        color: #0f172a;
    }

    .explore-subtitle {
        color: #64748b;
        font-size: 1.02rem;
        max-width: 920px;
        margin-bottom: 1rem;
        line-height: 1.55;
    }

    .narration-toolbar {
        display: flex;
        flex-wrap: wrap;
        align-items: end;
        gap: 0.9rem 1rem;
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 1rem;
        padding: 1rem 1rem 0.9rem;
        box-shadow: 0 10px 28px rgba(15, 23, 42, 0.06);
        margin-bottom: 1rem;
    }

    .toolbar-group {
        min-width: 240px;
        flex: 1 1 260px;
    }

    .toolbar-label {
        display: block;
        font-size: 0.88rem;
        font-weight: 700;
        color: #374151;
        margin-bottom: 0.45rem;
    }

    .toolbar-hint {
        width: 100%;
        font-size: 0.92rem;
        color: #6b7280;
        line-height: 1.55;
        margin-top: -0.1rem;
    }

    .map-shell {
        margin-bottom: 1rem;
    }

    .map-stage {
        position: relative;
        z-index: 1;
        height: 78vh;
        min-height: 640px;
        border-radius: 1.4rem;
        overflow: hidden;
        border: 1px solid #e5e7eb;
        box-shadow: 0 24px 48px rgba(15, 23, 42, 0.08);
        background: #fff;
    }

    #poiMap {
        width: 100%;
        height: 100%;
    }

    .map-status-card {
        position: absolute;
        top: 1rem;
        left: 1rem;
        z-index: 1000;
        width: 360px;
        max-width: calc(100% - 2rem);
        background: rgba(255, 255, 255, 0.96);
        backdrop-filter: blur(14px);
        border: 1px solid rgba(229, 231, 235, 0.95);
        border-radius: 1.15rem;
        box-shadow: 0 18px 40px rgba(15, 23, 42, 0.12);
        overflow: hidden;
    }

    .map-status-body {
        padding: 1rem;
    }

    .map-status-kicker {
        font-size: 0.76rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #6b7280;
        font-weight: 800;
        margin-bottom: 0.45rem;
    }

    .map-status-title {
        font-size: 1.08rem;
        font-weight: 800;
        color: #111827;
        line-height: 1.35;
        margin-bottom: 0.32rem;
    }

    .map-status-text {
        color: #4b5563;
        font-size: 0.94rem;
        line-height: 1.6;
        margin-bottom: 0.75rem;
    }

    .map-status-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
    }

    .map-status-chip {
        display: inline-flex;
        align-items: center;
        padding: 0.38rem 0.68rem;
        border-radius: 999px;
        background: #f3f4f6;
        color: #374151;
        font-size: 0.82rem;
        font-weight: 700;
    }

    .tour-action-bar {
        position: absolute;
        left: 1rem;
        right: 1rem;
        bottom: 1rem;
        z-index: 1000;
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem;
        justify-content: flex-start;
        pointer-events: none;
    }

    .tour-action-bar .btn,
    .tour-action-bar a {
        pointer-events: auto;
        border-radius: 0.85rem;
        font-weight: 700;
    }

    .custom-user-marker {
        width: 18px;
        height: 18px;
        border-radius: 999px;
        background: #2563eb;
        border: 3px solid #ffffff;
        box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.22);
    }

    .custom-poi-marker {
        width: 16px;
        height: 16px;
        border-radius: 999px;
        background: #ef4444;
        border: 2px solid #ffffff;
        box-shadow: 0 0 0 2px rgba(239, 68, 68, 0.18);
        position: relative;
    }

    .custom-poi-marker.active {
        background: #16a34a;
        box-shadow: 0 0 0 5px rgba(22, 163, 74, 0.24);
    }

    .custom-poi-marker.nearest {
        background: #f59e0b;
        box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.22);
    }

    .custom-poi-marker.completed {
        background: #64748b;
        box-shadow: 0 0 0 4px rgba(100, 116, 139, 0.18);
    }

    .custom-poi-marker.tour-stop {
        width: 28px;
        height: 28px;
        background: #0f172a;
        color: #ffffff;
        border: 2px solid #ffffff;
        box-shadow: 0 10px 18px rgba(15, 23, 42, 0.18);
    }

    .custom-poi-marker.tour-stop.nearest {
        background: #f59e0b;
        color: #111827;
        box-shadow: 0 0 0 5px rgba(245, 158, 11, 0.24);
    }

    .custom-poi-marker.tour-stop.active {
        background: #16a34a;
        color: #ffffff;
        box-shadow: 0 0 0 6px rgba(22, 163, 74, 0.24);
    }

    .custom-poi-marker.tour-stop.completed {
        background: #94a3b8;
        color: #ffffff;
        box-shadow: 0 0 0 5px rgba(148, 163, 184, 0.2);
    }

    .tour-stop-number {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.82rem;
        font-weight: 800;
        line-height: 1;
    }

    .leaflet-popup-content-wrapper {
        border-radius: 1rem;
        box-shadow: 0 18px 40px rgba(15, 23, 42, 0.16);
    }

    .leaflet-popup-content {
        margin: 0;
        min-width: 260px;
        font-family: "Be Vietnam Pro", Arial, Helvetica, sans-serif;
    }

    .popup-shell {
        padding: 0.9rem;
    }

    .popup-image {
        width: 100%;
        height: 140px;
        object-fit: cover;
        border-radius: 0.85rem;
        display: block;
        margin-bottom: 0.8rem;
    }

    .popup-title {
        font-size: 1rem;
        font-weight: 800;
        color: #111827;
        line-height: 1.45;
        margin-bottom: 0.45rem;
        word-break: break-word;
    }

    .popup-address {
        font-size: 0.92rem;
        color: #4b5563;
        line-height: 1.55;
        margin-bottom: 0.75rem;
    }

    .popup-actions {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .popup-btn-primary,
    .popup-btn-secondary {
        display: inline-block;
        padding: 0.52rem 0.84rem;
        border-radius: 0.72rem;
        font-size: 0.88rem;
        font-weight: 800;
        text-decoration: none;
        transition: all 0.18s ease;
        border: 1px solid transparent;
    }

    .popup-btn-primary {
        background: #111827;
        color: #ffffff !important;
        border-color: #111827;
    }

    .popup-btn-primary:hover {
        background: #000000;
        color: #ffffff !important;
    }

    .popup-btn-secondary {
        background: #ffffff;
        color: #2563eb !important;
        border-color: #bfdbfe;
    }

    .popup-btn-secondary:hover {
        background: #eff6ff;
        color: #1d4ed8 !important;
    }

    @@media (max-width: 1199.98px) {
        .map-stage {
            height: 72vh;
            min-height: 600px;
        }
    }

    @@media (max-width: 991.98px) {
        .explore-title {
            font-size: 2rem;
        }

        .map-shell {
            padding: 0 0.35rem;
        }

        .map-stage {
            height: 780px;
            min-height: 780px;
        }

        .map-status-card {
            width: auto;
            right: 1rem;
            max-width: none;
        }
    }

    @@media (max-width: 575.98px) {
        .explore-title {
            font-size: 1.8rem;
        }

        .narration-toolbar {
            padding: 0.9rem;
            border-radius: 0.95rem;
        }

        .toolbar-group {
            min-width: 100%;
            flex-basis: 100%;
        }

        .map-shell {
            padding: 0 0.45rem;
        }

        .map-stage {
            height: 720px;
            min-height: 720px;
            border-radius: 1.1rem;
        }

        .map-status-card {
            top: 0.8rem;
            left: 0.8rem;
            right: 0.8rem;
            width: auto;
        }

        .tour-action-bar {
            left: 0.8rem;
            right: 0.8rem;
            bottom: 0.8rem;
            gap: 0.45rem;
        }

        .tour-action-bar .btn,
        .tour-action-bar a {
            flex: 1 1 auto;
            text-align: center;
        }
    }

    #poiMap,
    .leaflet-container,
    .leaflet-pane,
    .leaflet-control-container {
        z-index: 1 !important;
    }
</style>

<div class="explore-hero">
    <h1 class="explore-title">@ui.exploreTitle</h1>
    <p class="explore-subtitle">@ui.exploreSubtitle</p>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger mb-4">
        @Model.ErrorMessage
    </div>
}

<div class="narration-toolbar">
    <div class="toolbar-group">
        <form method="get" asp-action="Index" id="narrationLanguageForm">
            <input type="hidden" name="lang" value="@currentLang" />

            @if (Model.IsTourMode && Model.SelectedTour != null)
            {
                <input type="hidden" name="tourId" value="@Model.SelectedTour.Id" />
                <input type="hidden" name="startTour" value="true" />
            }

            @if (Context.Request.Query.ContainsKey("focusStallId"))
            {
                <input type="hidden" name="focusStallId" value="@Context.Request.Query["focusStallId"]" />
            }

            <label for="langNarration" class="toolbar-label">@T("Ngôn ngữ thuyết minh", "Narration language")</label>
            <select id="langNarration" name="voiceLang" class="form-select" onchange="this.form.submit()">
                @foreach (var language in Model.Languages)
                {
                    if (language.LanguageCode == currentVoiceLang)
                    {
                        <option value="@language.LanguageCode" selected>@language.DisplayName</option>
                    }
                    else
                    {
                        <option value="@language.LanguageCode">@language.DisplayName</option>
                    }
                }
            </select>
        </form>
    </div>

    <div class="toolbar-hint">
        @ui.toolbarHint
    </div>
</div>

<div class="map-shell">
    <div class="map-stage">
        <div id="poiMap"></div>

        <div class="map-status-card">
            <div class="map-status-body">
                <div id="statusModeLabel" class="map-status-kicker">
                    @(Model.IsTourMode ? ui.tourMode : ui.exploreMode)
                </div>

                <div id="statusTitle" class="map-status-title">
                    @(Model.IsTourMode && Model.SelectedTour != null
                        ? (string.IsNullOrWhiteSpace(Model.SelectedTour.Name) ? $"Tour #{Model.SelectedTour.Id}" : Model.SelectedTour.Name)
                        : ui.noNarration)
                </div>

                <div id="statusText" class="map-status-text">
                    @if (Model.IsTourMode && Model.SelectedTour != null)
                    {
                        @ui.tourReady
                    }
                    else
                    {
                        @ui.noSimulatedPosition
                    }
                </div>

                <div id="statusChipRow" class="map-status-chips" style="display:none;">
                    <div id="statusChip1" class="map-status-chip"></div>
                    <div id="statusChip2" class="map-status-chip"></div>
                </div>
            </div>
        </div>

        @if (Model.IsTourMode && Model.SelectedTour != null)
        {
            <div class="tour-action-bar">
                <button type="button" id="tourMapPrimaryButton" class="btn btn-warning btn-sm">
                    @ui.nextButton
                </button>

                <button type="button" id="tourMapSecondaryButton" class="btn btn-outline-secondary btn-sm" style="display:none;"></button>

                <a asp-controller="Home"
                   asp-action="Index"
                   asp-route-lang="@currentLang"
                   asp-route-voiceLang="@currentVoiceLang"
                   id="tourMapExitButton"
                   class="btn btn-outline-dark btn-sm">
                    @ui.backToExplore
                </a>
            </div>
        }
    </div>
</div>

<audio id="audioPlayer" preload="auto"></audio>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
            crossorigin=""></script>

    <script>
        (() => {
            const apiBaseUrl = "http://audioguideapi.somee.com";

            function generateVisitToken() {
                const cryptoObj = window.crypto || window.msCrypto;

                if (cryptoObj && typeof cryptoObj.randomUUID === "function") {
                    return cryptoObj.randomUUID();
                }

                return `visit_${Date.now()}_${Math.random().toString(36).slice(2, 12)}`;
            }

            const visitKey = "audioGuideVisitToken";
            let visitToken = localStorage.getItem(visitKey);

            if (!visitToken) {
                visitToken = generateVisitToken();
                localStorage.setItem(visitKey, visitToken);
            }

            const currentLanguage = "@currentVoiceLang";
            const currentInterfaceLanguage = "@currentLang";
            const isTourMode = @Model.IsTourMode.ToString().ToLowerInvariant();
            const uiText = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ui));

            const focusStallId = Number("@(Context.Request.Query["focusStallId"].FirstOrDefault() ?? "0")");

            const rawSelectedTour = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SelectedTour));
            const selectedTour = rawSelectedTour
                ? {
                    id: rawSelectedTour.id ?? rawSelectedTour.Id,
                    name: rawSelectedTour.name ?? rawSelectedTour.Name,
                    stopCount: Number(rawSelectedTour.stopCount ?? rawSelectedTour.StopCount ?? 0),
                    stops: (rawSelectedTour.stops ?? rawSelectedTour.Stops ?? []).map(stop => ({
                        foodStallId: Number(stop.foodStallId ?? stop.FoodStallId),
                        orderIndex: Number(stop.orderIndex ?? stop.OrderIndex),
                        name: stop.name ?? stop.Name ?? "",
                        address: stop.address ?? stop.Address ?? "",
                        latitude: Number(stop.latitude ?? stop.Latitude),
                        longitude: Number(stop.longitude ?? stop.Longitude),
                        radius: Number(stop.radius ?? stop.Radius),
                        mapLink: stop.mapLink ?? stop.MapLink ?? ""
                    }))
                }
                : null;

            const audioPlayer = document.getElementById("audioPlayer");

            const statusModeLabel = document.getElementById("statusModeLabel");
            const statusTitle = document.getElementById("statusTitle");
            const statusText = document.getElementById("statusText");
            const statusChipRow = document.getElementById("statusChipRow");
            const statusChip1 = document.getElementById("statusChip1");
            const statusChip2 = document.getElementById("statusChip2");

            const tourMapPrimaryButton = document.getElementById("tourMapPrimaryButton");
            const tourMapSecondaryButton = document.getElementById("tourMapSecondaryButton");

            let currentTriggeredStallId = null;
            let currentTriggeredAt = 0;

            let activePlaybackSession = null;
            let currentNearestStallId = null;
            let activeTargetStallId = null;
            let activePopupMarker = null;
            let currentObjectUrl = null;

            let completedTourStopIds = [];
            let pendingTourBypassTarget = null;

            let currentRouteLine = null;
            let currentRouteDistance = null;
            let lastRouteOrigin = null;

            const cooldownMs = 45000;
            const foodStalls = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FoodStalls));

            function getFoodStalls() {
                return (foodStalls || []).map(stall => ({
                    id: Number(stall.id ?? stall.Id),
                    name: stall.name ?? stall.Name ?? "",
                    address: stall.address ?? stall.Address ?? "",
                    specialty: stall.specialty ?? stall.Specialty ?? "",
                    priceRange: stall.priceRange ?? stall.PriceRange ?? "",
                    imageUrl: stall.imageUrl ?? stall.ImageUrl ?? "",
                    latitude: Number(stall.latitude ?? stall.Latitude),
                    longitude: Number(stall.longitude ?? stall.Longitude),
                    radius: Number(stall.radius ?? stall.Radius),
                    description: stall.description ?? stall.Description ?? "",
                    audioUrl: stall.audioUrl ?? stall.AudioUrl ?? "",
                    priority: Number(stall.priority ?? stall.Priority),
                    mapLink: stall.mapLink ?? stall.MapLink ?? "",
                    languageCode: currentLanguage
                }));
            }

            function getOrderedTourStops() {
                if (!selectedTour || !selectedTour.stops || !Array.isArray(selectedTour.stops)) {
                    return [];
                }

                return [...selectedTour.stops].sort((a, b) => a.orderIndex - b.orderIndex);
            }

            function getNextTourStop() {
                const orderedStops = getOrderedTourStops();

                for (const stop of orderedStops) {
                    if (!completedTourStopIds.includes(Number(stop.foodStallId))) {
                        return stop;
                    }
                }

                return null;
            }

            function getCompletedTourStopCount() {
                return completedTourStopIds.length;
            }

            function markTourStopCompleted(foodStallId) {
                if (!isTourMode) return;

                const stopId = Number(foodStallId);

                if (!completedTourStopIds.includes(stopId)) {
                    completedTourStopIds.push(stopId);
                }
            }

            function findTourStopByFoodStallId(foodStallId) {
                return getOrderedTourStops().find(x => Number(x.foodStallId) === Number(foodStallId)) || null;
            }

            function isFoodStallInTour(foodStallId) {
                return !!findTourStopByFoodStallId(foodStallId);
            }

            function getTourSequenceNumber(foodStallId) {
                const orderedStops = getOrderedTourStops();
                const index = orderedStops.findIndex(x => Number(x.foodStallId) === Number(foodStallId));
                return index >= 0 ? index + 1 : null;
            }

            function setStatusCard(modeLabel, title, text, chip1 = null, chip2 = null) {
                if (statusModeLabel) statusModeLabel.textContent = modeLabel;
                if (statusTitle) statusTitle.textContent = title;
                if (statusText) statusText.innerHTML = text;

                if (statusChipRow && statusChip1 && statusChip2) {
                    if (chip1 || chip2) {
                        statusChipRow.style.display = "flex";

                        if (chip1) {
                            statusChip1.style.display = "inline-flex";
                            statusChip1.textContent = chip1;
                        } else {
                            statusChip1.style.display = "none";
                            statusChip1.textContent = "";
                        }

                        if (chip2) {
                            statusChip2.style.display = "inline-flex";
                            statusChip2.textContent = chip2;
                        } else {
                            statusChip2.style.display = "none";
                            statusChip2.textContent = "";
                        }
                    } else {
                        statusChipRow.style.display = "none";
                        statusChip1.style.display = "none";
                        statusChip2.style.display = "none";
                        statusChip1.textContent = "";
                        statusChip2.textContent = "";
                    }
                }
            }

            function setTourActionButtons(primaryText = null, primaryHandler = null, secondaryText = null, secondaryHandler = null) {
                if (tourMapPrimaryButton) {
                    if (primaryText && primaryHandler) {
                        tourMapPrimaryButton.style.display = "inline-block";
                        tourMapPrimaryButton.textContent = primaryText;
                        tourMapPrimaryButton.onclick = primaryHandler;
                    } else {
                        tourMapPrimaryButton.style.display = "none";
                        tourMapPrimaryButton.textContent = "";
                        tourMapPrimaryButton.onclick = null;
                    }
                }

                if (tourMapSecondaryButton) {
                    if (secondaryText && secondaryHandler) {
                        tourMapSecondaryButton.style.display = "inline-block";
                        tourMapSecondaryButton.textContent = secondaryText;
                        tourMapSecondaryButton.onclick = secondaryHandler;
                    } else {
                        tourMapSecondaryButton.style.display = "none";
                        tourMapSecondaryButton.textContent = "";
                        tourMapSecondaryButton.onclick = null;
                    }
                }
            }

            function clearTourActionButtons() {
                setTourActionButtons(
                    uiText.nextButton,
                    async () => await simulateNextTourStop(),
                    null,
                    null
                );

                pendingTourBypassTarget = null;
            }

            function updateTourStatusSummary(subTextOverride = null, chip2Override = null) {
                if (!isTourMode || !selectedTour) return;

                const completedCount = getCompletedTourStopCount();
                const totalCount = Number(selectedTour.stopCount ?? 0);
                const nextStop = getNextTourStop();

                const tourName = selectedTour.name && selectedTour.name.trim() !== ""
                    ? selectedTour.name
                    : `Tour #${selectedTour.id}`;

                if (!nextStop) {
                    setStatusCard(
                        uiText.tourMode,
                        tourName,
                        uiText.completedTour,
                        `${uiText.progress} ${completedCount}/${totalCount}`,
                        null
                    );
                    return;
                }

                setStatusCard(
                    uiText.tourMode,
                    tourName,
                    subTextOverride ?? `${uiText.nextStop}: <strong>${nextStop.name || ("Stop #" + nextStop.orderIndex)}</strong>.`,
                    `${uiText.progress} ${completedCount}/${totalCount}`,
                    chip2Override ?? `${uiText.nextStop} ${nextStop.orderIndex}`
                );
            }

            function setExploreIdleStatus(nearest = null) {
                if (nearest) {
                    setStatusCard(
                        uiText.exploreMode,
                        uiText.noNarration,
                        `${uiText.currentNearest} <strong>${nearest.name}</strong>.`,
                        `${nearest.distance.toFixed(1)} m`,
                        null
                    );
                } else {
                    setStatusCard(
                        uiText.exploreMode,
                        uiText.noNarration,
                        uiText.noSimulatedPosition,
                        null,
                        null
                    );
                }
            }

            function setExploreActiveStatus(target, secondaryText) {
                setStatusCard(
                    uiText.exploreMode,
                    target.name,
                    secondaryText,
                    `${uiText.distanceFromYou ?? "Distance"} ${target.distance.toFixed(1)} m`,
                    null
                );
            }

            function haversineDistanceMeters(lat1, lon1, lat2, lon2) {
                const toRad = deg => deg * Math.PI / 180;
                const R = 6371000;

                const dLat = toRad(lat2 - lat1);
                const dLon = toRad(lon2 - lon1);

                const a =
                    Math.sin(dLat / 2) * Math.sin(dLat / 2) +
                    Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) *
                    Math.sin(dLon / 2) * Math.sin(dLon / 2);

                const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
                return R * c;
            }

            const defaultCenter = [10.7588, 106.6857];
            const map = L.map("poiMap").setView(defaultCenter, 17);

            L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
                maxZoom: 20,
                attribution: "&copy; OpenStreetMap contributors"
            }).addTo(map);

            const poiMarkers = new Map();
            const poiRadiusCircles = new Map();

            const userIcon = L.divIcon({
                className: "",
                html: `<div class="custom-user-marker"></div>`,
                iconSize: [18, 18],
                iconAnchor: [9, 9]
            });

            let userMarker = null;

            function createPoiIcon(mode, stallId) {
                const inTour = isTourMode && isFoodStallInTour(stallId);
                const sequenceNumber = inTour ? getTourSequenceNumber(stallId) : null;
                const isCompleted = completedTourStopIds.includes(Number(stallId));

                let classes = "custom-poi-marker";
                if (inTour) classes += " tour-stop";
                if (mode === "active") classes += " active";
                else if (mode === "nearest") classes += " nearest";
                else if (isCompleted) classes += " completed";

                const innerHtml = inTour
                    ? `<div class="tour-stop-number">${sequenceNumber}</div>`
                    : "";

                return L.divIcon({
                    className: "",
                    html: `<div class="${classes}">${innerHtml}</div>`,
                    iconSize: inTour ? [28, 28] : [16, 16],
                    iconAnchor: inTour ? [14, 14] : [8, 8]
                });
            }

            function buildPopupHtml(stall) {
                const imageHtml = stall.imageUrl
                    ? `<img src="${stall.imageUrl}" alt="${stall.name}" class="popup-image" />`
                    : "";

                const mapLinkHtml = stall.mapLink
                    ? `<a href="${stall.mapLink}" target="_blank" rel="noopener noreferrer" class="popup-btn-secondary">${uiText.openMap}</a>`
                    : "";

                const tourHintHtml = isTourMode && isFoodStallInTour(stall.id)
                    ? `<div style="margin-top:0.55rem; color:#6b7280; font-size:0.85rem;">${uiText.inTourStop} ${getTourSequenceNumber(stall.id)}</div>`
                    : "";

                return `
                    <div class="popup-shell">
                        ${imageHtml}
                        <div class="popup-title">${stall.name}</div>
                        <div class="popup-address">${stall.address || uiText.noAddress}</div>
                        ${tourHintHtml}
                        <div class="popup-actions">
                            <a href="/FoodStalls/Details/${stall.id}?lang=${encodeURIComponent(currentInterfaceLanguage)}&voiceLang=${encodeURIComponent(currentLanguage)}" class="popup-btn-primary">${uiText.details}</a>
                            ${mapLinkHtml}
                        </div>
                    </div>
                `;
            }

            function renderPoiMarkers() {
                const stalls = getFoodStalls();

                stalls.forEach(stall => {
                    const marker = L.marker([stall.latitude, stall.longitude], {
                        icon: createPoiIcon("default", stall.id)
                    }).addTo(map);

                    marker.bindPopup(buildPopupHtml(stall));

                    marker.on("click", async (e) => {
                        L.DomEvent.stopPropagation(e);

                        if (isTourMode) {
                            await handleTourDemoPoiSelection(stall.id);
                            return;
                        }

                        activeTargetStallId = stall.id;
                        updateMapMarkerStates();
                        openActivePopup(stall.id);
                    });

                    poiMarkers.set(stall.id, marker);

                    const circle = L.circle([stall.latitude, stall.longitude], {
                        radius: stall.radius,
                        color: "#cbd5e1",
                        weight: 1,
                        fillOpacity: 0.04
                    }).addTo(map);

                    poiRadiusCircles.set(stall.id, circle);
                });

                if (stalls.length > 0) {
                    const group = L.featureGroup([
                        ...Array.from(poiMarkers.values()),
                        ...Array.from(poiRadiusCircles.values())
                    ]);
                    map.fitBounds(group.getBounds().pad(0.1));
                }
            }

            function updateUserMarker(lat, lng) {
                if (!userMarker) {
                    userMarker = L.marker([lat, lng], { icon: userIcon }).addTo(map);
                    userMarker.bindPopup(uiText.simulatedPosition);
                } else {
                    userMarker.setLatLng([lat, lng]);
                }
            }

            function openActivePopup(stallId) {
                const marker = poiMarkers.get(stallId);
                if (!marker) return;

                if (activePopupMarker && activePopupMarker !== marker) {
                    activePopupMarker.closePopup();
                }

                marker.openPopup();
                activePopupMarker = marker;
            }

            function updateMapMarkerStates() {
                const stalls = getFoodStalls();

                stalls.forEach(stall => {
                    const marker = poiMarkers.get(stall.id);
                    const circle = poiRadiusCircles.get(stall.id);

                    if (!marker || !circle) return;

                    let mode = "default";

                    if (activeTargetStallId === stall.id) {
                        mode = "active";
                    } else if (currentNearestStallId === stall.id) {
                        mode = "nearest";
                    }

                    marker.setIcon(createPoiIcon(mode, stall.id));

                    if (activeTargetStallId === stall.id) {
                        circle.setStyle({
                            color: "#16a34a",
                            fillOpacity: 0.12,
                            weight: 2
                        });
                    } else if (currentNearestStallId === stall.id) {
                        circle.setStyle({
                            color: "#f59e0b",
                            fillOpacity: 0.08,
                            weight: 2
                        });
                    } else if (isTourMode && completedTourStopIds.includes(stall.id)) {
                        circle.setStyle({
                            color: "#94a3b8",
                            fillOpacity: 0.06,
                            weight: 2
                        });
                    } else if (isTourMode && isFoodStallInTour(stall.id)) {
                        circle.setStyle({
                            color: "#94a3b8",
                            fillOpacity: 0.05,
                            weight: 1.5
                        });
                    } else {
                        circle.setStyle({
                            color: "#cbd5e1",
                            fillOpacity: 0.04,
                            weight: 1
                        });
                    }
                });
            }

            function focusOnStall(stallId) {
                const stall = getFoodStalls().find(x => x.id === Number(stallId));
                const marker = poiMarkers.get(Number(stallId));

                if (!stall || !marker) return;

                map.flyTo([stall.latitude, stall.longitude], 18, {
                    animate: true,
                    duration: 0.8
                });

                openActivePopup(stall.id);
            }

            function focusStallFromQueryIfNeeded() {
                if (!focusStallId || focusStallId <= 0) return;

                const stall = getFoodStalls().find(x => Number(x.id) === Number(focusStallId));
                if (!stall) return;

                activeTargetStallId = stall.id;
                currentNearestStallId = stall.id;

                updateMapMarkerStates();

                setTimeout(() => {
                    focusOnStall(stall.id);
                }, 350);

                if (!isTourMode) {
                    setExploreActiveStatus(
                        {
                            ...stall,
                            distance: 0
                        },
                        uiText.showOnMap
                    );
                }
            }

            function updateNearestPoi(lat, lng) {
                const stalls = getFoodStalls();

                if (stalls.length === 0) {
                    currentNearestStallId = null;
                    updateMapMarkerStates();
                    return null;
                }

                const nearest = stalls
                    .map(stall => ({
                        ...stall,
                        distance: haversineDistanceMeters(lat, lng, stall.latitude, stall.longitude)
                    }))
                    .sort((a, b) => a.distance - b.distance)[0];

                currentNearestStallId = nearest ? nearest.id : null;
                updateMapMarkerStates();
                return nearest;
            }

            function resolveTarget(userLat, userLng) {
                const candidates = getFoodStalls()
                    .map(stall => ({
                        ...stall,
                        distance: haversineDistanceMeters(userLat, userLng, stall.latitude, stall.longitude)
                    }))
                    .filter(stall => stall.distance <= stall.radius);

                if (candidates.length === 0) return null;

                candidates.sort((a, b) => {
                    if (a.priority !== b.priority) {
                        return a.priority - b.priority;
                    }

                    return a.distance - b.distance;
                });

                return candidates[0];
            }

            function resolveClickedPoi(lat, lng) {
                const candidates = getFoodStalls()
                    .map(stall => ({
                        ...stall,
                        distance: haversineDistanceMeters(lat, lng, stall.latitude, stall.longitude)
                    }))
                    .filter(stall => stall.distance <= stall.radius)
                    .sort((a, b) => a.distance - b.distance);

                return candidates.length > 0 ? candidates[0] : null;
            }

            function classifyTourPosition(lat, lng) {
                const nextStop = getNextTourStop();

                if (!nextStop) {
                    return {
                        type: "COMPLETED",
                        nextStop: null,
                        matchedPoi: null,
                        matchedTourStop: null,
                        straightDistanceToNextStop: 0
                    };
                }

                const matchedPoi = resolveClickedPoi(lat, lng);
                const straightDistanceToNextStop = haversineDistanceMeters(
                    lat,
                    lng,
                    Number(nextStop.latitude),
                    Number(nextStop.longitude)
                );

                if (!matchedPoi) {
                    return {
                        type: "EMPTY",
                        nextStop,
                        matchedPoi: null,
                        matchedTourStop: null,
                        straightDistanceToNextStop
                    };
                }

                const matchedTourStop = findTourStopByFoodStallId(matchedPoi.id);

                if (!matchedTourStop) {
                    return {
                        type: "OUTSIDE_TOUR",
                        nextStop,
                        matchedPoi,
                        matchedTourStop: null,
                        straightDistanceToNextStop
                    };
                }

                if (Number(matchedTourStop.foodStallId) !== Number(nextStop.foodStallId)) {
                    return {
                        type: "WRONG_STOP",
                        nextStop,
                        matchedPoi,
                        matchedTourStop,
                        straightDistanceToNextStop
                    };
                }

                return {
                    type: "NEXT_STOP",
                    nextStop,
                    matchedPoi,
                    matchedTourStop,
                    straightDistanceToNextStop
                };
            }

            function shouldSkipTrigger(target) {
                const now = Date.now();
                return currentTriggeredStallId === Number(target.id) && (now - currentTriggeredAt) < cooldownMs;
            }

            async function fetchRoute(fromLat, fromLng, toLat, toLng) {
                const url = `https://router.project-osrm.org/route/v1/foot/${fromLng},${fromLat};${toLng},${toLat}?overview=full&geometries=geojson`;

                const response = await fetch(url);

                if (!response.ok) {
                    console.error("Route API error:", response.status);
                    return null;
                }

                const data = await response.json();

                if (!data.routes || data.routes.length === 0) {
                    return null;
                }

                const route = data.routes[0];

                return {
                    distance: route.distance,
                    geometry: route.geometry.coordinates.map(c => [c[1], c[0]])
                };
            }

            function drawRoute(geometry) {
                if (!geometry || geometry.length === 0) return;

                if (currentRouteLine) {
                    currentRouteLine.setLatLngs(geometry);
                } else {
                    currentRouteLine = L.polyline(geometry, {
                        color: "#2563eb",
                        weight: 5,
                        opacity: 0.9
                    }).addTo(map);
                }
            }

            function clearRoute() {
                if (currentRouteLine) {
                    map.removeLayer(currentRouteLine);
                    currentRouteLine = null;
                }

                currentRouteDistance = null;
                lastRouteOrigin = null;
            }

            async function updateRoute(userLat, userLng, force = false) {
                if (!isTourMode) return;

                const nextStop = getNextTourStop();

                if (!nextStop) {
                    clearRoute();
                    return;
                }

                const shouldUpdate =
                    force ||
                    !lastRouteOrigin ||
                    haversineDistanceMeters(
                        userLat,
                        userLng,
                        lastRouteOrigin.lat,
                        lastRouteOrigin.lng
                    ) > 30;

                if (!shouldUpdate) return;

                lastRouteOrigin = { lat: userLat, lng: userLng };

                const result = await fetchRoute(
                    userLat,
                    userLng,
                    Number(nextStop.latitude),
                    Number(nextStop.longitude)
                );

                if (!result) return;

                currentRouteDistance = result.distance;
                drawRoute(result.geometry);
            }

            async function refreshRoute() {
                if (!lastRouteOrigin) return;
                await updateRoute(lastRouteOrigin.lat, lastRouteOrigin.lng, true);
            }

            async function startPlaybackSession(target) {
                const payload = {
                    foodStallId: Number(target.id),
                    languageCode: target.languageCode || currentLanguage,
                    triggerType: isTourMode ? "TOUR" : "DEMO"
                };

                const response = await fetch(`${apiBaseUrl}/api/PlaybackLogs/start`, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify(payload)
                });

                if (!response.ok) {
                    throw new Error(`Start playback failed: ${response.status}`);
                }

                return await response.json();
            }

            async function finishPlaybackSession(status) {
                if (!activePlaybackSession) return;

                const finishedSession = activePlaybackSession;
                const finishedTargetId = Number(finishedSession.targetId);

                const actualDurationSeconds = Math.max(
                    0,
                    Math.round((Date.now() - finishedSession.startedAtMs) / 1000)
                );

                const payload = {
                    playbackLogId: finishedSession.playbackLogId,
                    status: status,
                    actualDurationSeconds: actualDurationSeconds
                };

                try {
                    const response = await fetch(`${apiBaseUrl}/api/PlaybackLogs/finish`, {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json"
                        },
                        body: JSON.stringify(payload)
                    });

                    if (!response.ok) {
                        console.error("Finish playback thất bại:", response.status);
                    }

                    if (status === "Completed" && isTourMode && finishedSession.shouldCompleteTourStop) {
                        markTourStopCompleted(finishedTargetId);
                        await refreshRoute();

                        const upcomingStop = getNextTourStop();

                        if (upcomingStop) {
                            currentNearestStallId = Number(upcomingStop.foodStallId);
                            activeTargetStallId = null;
                            updateMapMarkerStates();

                            updateTourStatusSummary(
                                `${uiText.finishedStop} ${uiText.nextIs} <strong>${upcomingStop.name ?? ("Stop #" + upcomingStop.orderIndex)}</strong>.`,
                                `${uiText.nextStop} ${upcomingStop.orderIndex}`
                            );

                            clearTourActionButtons();
                        } else {
                            currentNearestStallId = null;
                            activeTargetStallId = null;
                            updateMapMarkerStates();
                            clearRoute();

                            setStatusCard(
                                uiText.tourMode,
                                selectedTour?.name || "Tour",
                                uiText.completedTour,
                                `${uiText.progress} ${getCompletedTourStopCount()}/${Number(selectedTour?.stopCount ?? 0)}`,
                                null
                            );

                            setTourActionButtons(null, null, null, null);
                        }
                    } else if (status !== "Completed" && isTourMode) {
                        clearTourActionButtons();
                    }
                } catch (error) {
                    console.error("Lỗi khi finish playback:", error);
                } finally {
                    activePlaybackSession = null;
                }
            }

            function clearGeneratedAudioUrl() {
                if (currentObjectUrl) {
                    URL.revokeObjectURL(currentObjectUrl);
                    currentObjectUrl = null;
                }
            }

            async function synthesizeTtsAudio(target) {
                const payload = {
                    text: target.description,
                    languageCode: target.languageCode || currentLanguage
                };

                const response = await fetch(`${apiBaseUrl}/api/Tts/synthesize`, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify(payload)
                });

                if (!response.ok) {
                    let errorMessage = `TTS failed: ${response.status}`;

                    try {
                        const errorJson = await response.json();
                        if (errorJson?.detail) errorMessage = errorJson.detail;
                        else if (errorJson?.message) errorMessage = errorJson.message;
                    } catch {
                    }

                    throw new Error(errorMessage);
                }

                const audioBlob = await response.blob();
                clearGeneratedAudioUrl();
                currentObjectUrl = URL.createObjectURL(audioBlob);
                return currentObjectUrl;
            }

            async function interruptActivePlaybackIfAny() {
                if (activePlaybackSession) {
                    await finishPlaybackSession("Interrupted");
                }

                audioPlayer.pause();
                audioPlayer.currentTime = 0;
                audioPlayer.removeAttribute("src");
                audioPlayer.load();
                clearGeneratedAudioUrl();
            }

            async function playTarget(target) {
                const targetId = Number(target.id);

                currentTriggeredStallId = targetId;
                currentTriggeredAt = Date.now();
                activeTargetStallId = targetId;

                const expectedTourStop = isTourMode ? getNextTourStop() : null;
                const shouldCompleteTourStop =
                    isTourMode &&
                    expectedTourStop &&
                    Number(expectedTourStop.foodStallId) === targetId;

                if (isTourMode) {
                    const totalCount = Number(selectedTour?.stopCount ?? 0);
                    setStatusCard(
                        uiText.tourMode,
                        selectedTour?.name || "Tour",
                        `${uiText.playingAt} <strong>${target.name}</strong>.`,
                        `${uiText.progress} ${getCompletedTourStopCount()}/${totalCount}`,
                        shouldCompleteTourStop ? `${uiText.nextStop} ${expectedTourStop.orderIndex}` : null
                    );
                } else {
                    setExploreActiveStatus(
                        target,
                        uiText.playingPlace
                    );
                }

                clearTourActionButtons();
                focusOnStall(targetId);
                updateMapMarkerStates();

                await interruptActivePlaybackIfAny();

                try {
                    const startResult = await startPlaybackSession(target);

                    activePlaybackSession = {
                        playbackLogId: startResult.playbackLogId,
                        startedAtMs: Date.now(),
                        targetId: targetId,
                        shouldCompleteTourStop: shouldCompleteTourStop,
                        type: target.audioUrl && target.audioUrl.trim() !== "" ? "audio" : "tts"
                    };

                    audioPlayer.onended = async () => {
                        await finishPlaybackSession("Completed");
                    };

                    if (target.audioUrl && target.audioUrl.trim() !== "") {
                        audioPlayer.src = target.audioUrl;
                        audioPlayer.currentTime = 0;
                        await audioPlayer.play();
                    } else if (target.description && target.description.trim() !== "") {
                        const generatedAudioUrl = await synthesizeTtsAudio(target);
                        audioPlayer.src = generatedAudioUrl;
                        audioPlayer.currentTime = 0;
                        await audioPlayer.play();
                    } else {
                        if (isTourMode) {
                            updateTourStatusSummary(uiText.noContentStop);
                        } else {
                            setExploreActiveStatus(target, uiText.noContentPlace);
                        }

                        await finishPlaybackSession("Stopped");
                    }
                } catch (error) {
                    console.error("Không thể bắt đầu playback session:", error);

                    if (isTourMode) {
                        updateTourStatusSummary(uiText.cannotStartStop);
                    } else {
                        setExploreActiveStatus(target, uiText.cannotStartPlace);
                    }

                    activePlaybackSession = null;
                    activeTargetStallId = null;
                    updateMapMarkerStates();
                }
            }

            async function processTourLocation(lat, lng) {
                updateUserMarker(lat, lng);
                await updateRoute(lat, lng);

                const context = classifyTourPosition(lat, lng);

                if (context.type === "COMPLETED") {
                    activeTargetStallId = null;
                    currentNearestStallId = null;
                    updateMapMarkerStates();
                    clearRoute();

                    setStatusCard(
                        uiText.tourMode,
                        selectedTour?.name || "Tour",
                        uiText.completedTour,
                        `${uiText.progress} ${getCompletedTourStopCount()}/${Number(selectedTour?.stopCount ?? 0)}`,
                        null
                    );

                    setTourActionButtons(null, null, null, null);
                    return;
                }

                const nextStop = context.nextStop;
                const displayDistance = currentRouteDistance ?? context.straightDistanceToNextStop;
                currentNearestStallId = Number(nextStop.foodStallId);

                if (context.type === "EMPTY") {
                    activeTargetStallId = null;
                    updateMapMarkerStates();

                    updateTourStatusSummary(
                        `${uiText.currentNearest} <strong>${stopName(nextStop)}</strong>.`,
                        `${displayDistance.toFixed(1)} m`
                    );

                    clearTourActionButtons();
                    return;
                }

                if (context.type === "OUTSIDE_TOUR") {
                    activeTargetStallId = null;
                    updateMapMarkerStates();
                    openActivePopup(context.matchedPoi.id);

                    updateTourStatusSummary(
                        `<strong>${context.matchedPoi.name}</strong> ${uiText.outsideTour}`,
                        `${displayDistance.toFixed(1)} m`
                    );

                    clearTourActionButtons();
                    return;
                }

                if (context.type === "WRONG_STOP") {
                    activeTargetStallId = Number(context.matchedPoi.id);
                    updateMapMarkerStates();
                    openActivePopup(context.matchedPoi.id);

                    pendingTourBypassTarget = {
                        ...context.matchedPoi,
                        distance: context.straightDistanceToNextStop
                    };

                    updateTourStatusSummary(
                        `${uiText.wrongStopPrefix} <strong>${context.matchedPoi.name}</strong>, ${uiText.wrongStopMiddle} <strong>${stopName(nextStop)}</strong>.`,
                        distanceChip(displayDistance)
                    );

                    setTourActionButtons(
                        uiText.nextButton,
                        async () => await simulateNextTourStop(),
                        uiText.stillListen,
                        async () => await playBypassTourTarget()
                    );

                    return;
                }

                if (context.type === "NEXT_STOP") {
                    const runtimeTarget = {
                        ...context.matchedPoi,
                        distance: context.straightDistanceToNextStop
                    };

                    if (shouldSkipTrigger(runtimeTarget)) {
                        activeTargetStallId = Number(runtimeTarget.id);
                        updateMapMarkerStates();
                        openActivePopup(runtimeTarget.id);

                        updateTourStatusSummary(
                            `${uiText.stillNear} <strong>${runtimeTarget.name}</strong> ${uiText.notReplay}`,
                            stopChip(context.matchedTourStop.orderIndex)
                        );

                        clearTourActionButtons();
                        return;
                    }

                    await playTarget(runtimeTarget);
                }
            }

            async function processLocation(lat, lng) {
                if (isTourMode) {
                    await processTourLocation(lat, lng);
                    return;
                }

                updateUserMarker(lat, lng);

                const nearest = updateNearestPoi(lat, lng);
                const target = resolveTarget(lat, lng);

                if (!target) {
                    activeTargetStallId = null;
                    updateMapMarkerStates();
                    setExploreIdleStatus(nearest);
                    return;
                }

                if (shouldSkipTrigger(target)) {
                    activeTargetStallId = Number(target.id);
                    updateMapMarkerStates();
                    openActivePopup(target.id);

                    setExploreActiveStatus(
                        target,
                        `${uiText.stillNear} <strong>${target.name}</strong> ${uiText.notReplay}`
                    );

                    return;
                }

                await playTarget(target);
            }

            async function simulateNextTourStop() {
                if (!isTourMode) return;

                const nextStop = getNextTourStop();

                if (!nextStop) {
                    setStatusCard(
                        uiText.tourMode,
                        selectedTour?.name || "Tour",
                        uiText.completedTour,
                        `${uiText.progress} ${getCompletedTourStopCount()}/${Number(selectedTour?.stopCount ?? 0)}`,
                        null
                    );

                    setTourActionButtons(null, null, null, null);
                    clearRoute();
                    return;
                }

                await processTourLocation(Number(nextStop.latitude), Number(nextStop.longitude));
            }

            async function playBypassTourTarget() {
                if (!pendingTourBypassTarget) return;

                const target = pendingTourBypassTarget;
                pendingTourBypassTarget = null;
                clearTourActionButtons();

                focusOnStall(target.id);
                await playTarget(target);
            }

            async function handleTourDemoMapClick(lat, lng) {
                updateUserMarker(lat, lng);
                await updateRoute(lat, lng);

                const context = classifyTourPosition(lat, lng);

                if (context.type === "COMPLETED") {
                    setStatusCard(
                        uiText.tourMode,
                        selectedTour?.name || "Tour",
                        uiText.completedTour,
                        `${uiText.progress} ${getCompletedTourStopCount()}/${Number(selectedTour?.stopCount ?? 0)}`,
                        null
                    );

                    setTourActionButtons(null, null, null, null);
                    clearRoute();
                    return;
                }

                if (context.type === "EMPTY") {
                    const displayDistance = currentRouteDistance ?? context.straightDistanceToNextStop;

                    currentNearestStallId = Number(context.nextStop.foodStallId);
                    activeTargetStallId = null;
                    updateMapMarkerStates();

                    updateTourStatusSummary(
                        `${uiText.currentNearest} <strong>${stopName(context.nextStop)}</strong>.`,
                        `${displayDistance.toFixed(1)} m`
                    );

                    clearTourActionButtons();
                    return;
                }

                await handleTourDemoPoiSelection(context.matchedPoi.id, { preserveUserMarker: true });
            }

            async function handleTourDemoPoiSelection(stallId, options = {}) {
                const { preserveUserMarker = false } = options;

                const clickedStall = getFoodStalls().find(x => x.id === Number(stallId));
                if (!clickedStall) return;

                if (!preserveUserMarker) {
                    updateUserMarker(clickedStall.latitude, clickedStall.longitude);
                    await updateRoute(clickedStall.latitude, clickedStall.longitude);
                }

                openActivePopup(clickedStall.id);

                const context = classifyTourPosition(clickedStall.latitude, clickedStall.longitude);

                if (context.type === "COMPLETED") {
                    setStatusCard(
                        uiText.tourMode,
                        selectedTour?.name || "Tour",
                        uiText.completedTour,
                        `${uiText.progress} ${getCompletedTourStopCount()}/${Number(selectedTour?.stopCount ?? 0)}`,
                        null
                    );

                    setTourActionButtons(null, null, null, null);
                    clearRoute();
                    return;
                }

                if (context.type === "OUTSIDE_TOUR") {
                    currentNearestStallId = Number(context.nextStop.foodStallId);
                    activeTargetStallId = null;
                    updateMapMarkerStates();

                    updateTourStatusSummary(
                        `<strong>${context.matchedPoi.name}</strong> ${uiText.outsideTour}`,
                        null
                    );

                    clearTourActionButtons();
                    return;
                }

                if (context.type === "WRONG_STOP") {
                    currentNearestStallId = Number(context.nextStop.foodStallId);
                    activeTargetStallId = Number(context.matchedPoi.id);
                    updateMapMarkerStates();

                    pendingTourBypassTarget = {
                        ...context.matchedPoi,
                        distance: context.straightDistanceToNextStop
                    };

                    updateTourStatusSummary(
                        `${uiText.wrongStopPrefix} <strong>${context.matchedPoi.name}</strong>, ${uiText.wrongStopMiddle} <strong>${stopName(context.nextStop)}</strong>.`,
                        stopChip(context.matchedTourStop.orderIndex)
                    );

                    setTourActionButtons(
                        uiText.nextButton,
                        async () => await simulateNextTourStop(),
                        uiText.stillListen,
                        async () => await playBypassTourTarget()
                    );

                    return;
                }

                if (context.type === "NEXT_STOP") {
                    currentNearestStallId = Number(context.nextStop.foodStallId);
                    updateMapMarkerStates();

                    const runtimeTarget = {
                        ...context.matchedPoi,
                        distance: 0
                    };

                    if (shouldSkipTrigger(runtimeTarget)) {
                        activeTargetStallId = Number(runtimeTarget.id);
                        updateMapMarkerStates();

                        updateTourStatusSummary(
                            `${uiText.stillNear} <strong>${runtimeTarget.name}</strong> ${uiText.notReplay}`,
                            stopChip(context.matchedTourStop.orderIndex)
                        );

                        clearTourActionButtons();
                        return;
                    }

                    await playTarget(runtimeTarget);
                }
            }

            function initializeScreen() {
                if (isTourMode) {
                    updateTourStatusSummary();
                    clearTourActionButtons();
                } else {
                    setExploreIdleStatus();
                }
            }

            map.on("click", async (e) => {
                const lat = e.latlng.lat;
                const lng = e.latlng.lng;

                if (isTourMode) {
                    await handleTourDemoMapClick(lat, lng);
                    return;
                }

                await processLocation(lat, lng);
            });

            async function startVisitTracking() {
                try {
                    const response = await fetch(`${apiBaseUrl}/api/WebVisits/start`, {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json"
                        },
                        body: JSON.stringify({
                            visitToken: visitToken,
                            userAgent: navigator.userAgent
                        })
                    });

                    console.log("Start tracking status:", response.status);
                } catch (error) {
                    console.error("Start tracking failed:", error);
                }
            }

            function startHeartbeat() {
                setInterval(async () => {
                    try {
                        const response = await fetch(`${apiBaseUrl}/api/WebVisits/heartbeat`, {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/json"
                            },
                            body: JSON.stringify({
                                visitToken: visitToken
                            })
                        });

                        console.log("Heartbeat status:", response.status);
                    } catch (error) {
                        console.error("Heartbeat failed:", error);
                    }
                }, 30000);
            }

            renderPoiMarkers();
            initializeScreen();

            setTimeout(() => {
                map.invalidateSize();
            }, 300);

            window.addEventListener("resize", () => {
                map.invalidateSize();
            });

            focusStallFromQueryIfNeeded();

            startVisitTracking();
            startHeartbeat();
        })();
    </script>
}