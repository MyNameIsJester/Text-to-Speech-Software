@{
    var currentLang = Context.Request.Query["lang"].FirstOrDefault() ?? "vi";
    var currentVoiceLang = Context.Request.Query["voiceLang"].FirstOrDefault() ?? currentLang;
    var isEnglish = currentLang == "en";

    string T(string vi, string en) => isEnglish ? en : vi;

    var controller = ViewContext.RouteData.Values["controller"]?.ToString();

    string BuildLanguageUrl(string lang)
    {
        var queryItems = Context.Request.Query
            .Where(x =>
                !string.Equals(x.Key, "lang", StringComparison.OrdinalIgnoreCase) &&
                !string.Equals(x.Key, "voiceLang", StringComparison.OrdinalIgnoreCase))
            .SelectMany(x => x.Value.Select(v => $"{Uri.EscapeDataString(x.Key)}={Uri.EscapeDataString(v ?? "")}"))
            .ToList();

        queryItems.Add($"lang={Uri.EscapeDataString(lang)}");
        queryItems.Add($"voiceLang={Uri.EscapeDataString(lang)}");

        return $"{Context.Request.Path}?{string.Join("&", queryItems)}";
    }
}

<!DOCTYPE html>
<html lang="@currentLang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Audio Guide</title>
    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AudioGuideWeb.styles.css" asp-append-version="true" />

    <style>
            body {
                background: #f7f8fa;
                color: #1f2937;
            }

            header {
                position: relative;
                z-index: 5000;
            }

            .app-navbar {
                position: relative;
                z-index: 5001;
                background: #ffffff;
                border-bottom: 1px solid #e5e7eb;
                box-shadow: 0 6px 20px rgba(0,0,0,0.04);
            }

                .app-navbar .navbar-brand {
                    position: relative;
                    z-index: 5002;
                    font-weight: 800;
                    font-size: 1.25rem;
                    color: #111827 !important;
                    letter-spacing: -0.02em;
                }

                .app-navbar .nav-link {
                    position: relative;
                    z-index: 5002;
                    color: #4b5563 !important;
                    font-weight: 600;
                    padding: 0.65rem 0.9rem !important;
                    border-radius: 0.75rem;
                    transition: all 0.2s ease;
                }

                    .app-navbar .nav-link:hover {
                        background: #f3f4f6;
                        color: #111827 !important;
                    }

                    .app-navbar .nav-link.active {
                        background: #111827;
                        color: #ffffff !important;
                    }

            .language-menu-button {
                display: inline-flex;
                align-items: center;
                gap: 0.45rem;
                border: 1px solid #e5e7eb;
                background: #ffffff;
                color: #111827;
                font-weight: 800;
                border-radius: 999px;
                padding: 0.58rem 0.9rem;
                box-shadow: 0 8px 22px rgba(15, 23, 42, 0.07);
                transition: all 0.18s ease;
            }

                .language-menu-button:hover,
                .language-menu-button:focus {
                    background: #f8fafc;
                    border-color: #cbd5e1;
                    box-shadow: 0 10px 26px rgba(15, 23, 42, 0.1);
                }

            .language-flag {
                font-size: 1.05rem;
                line-height: 1;
            }

            .language-dropdown {
                border: 1px solid #e5e7eb;
                border-radius: 0.9rem;
                padding: 0.45rem;
                box-shadow: 0 18px 42px rgba(15, 23, 42, 0.14);
            }

            .language-dropdown-item {
                display: flex;
                align-items: center;
                gap: 0.55rem;
                border-radius: 0.65rem;
                font-weight: 700;
                padding: 0.55rem 0.75rem;
            }

                .language-dropdown-item.active {
                    background: #111827;
                    color: #ffffff;
                }

                .language-dropdown-item:hover {
                    background: #f3f4f6;
                    color: #111827;
                }

            .app-page {
                position: relative;
                z-index: 1;
                padding-top: 1.5rem;
                padding-bottom: 2rem;
                min-height: calc(100vh - 140px);
            }

            .app-footer {
                position: relative;
                z-index: 1;
                border-top: 1px solid #e5e7eb;
                background: #ffffff;
                color: #6b7280;
                font-size: 0.95rem;
                padding: 1rem 0;
            }

            @@media (max-width: 991.98px) {
                .language-menu-button {
                    width: 100%;
                    justify-content: center;
                    margin-top: 0.35rem;
                }
            }
    </style>
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg app-navbar">
            <div class="container">
                <a class="navbar-brand"
                       asp-controller="Home"
                       asp-action="Index"
                       asp-route-lang="@currentLang"
                       asp-route-voiceLang="@currentVoiceLang">
                    Audio Guide
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
                        <li class="nav-item">
                            <a class="nav-link @(controller == "Home" ? "active" : "")"
                                   asp-controller="Home"
                                   asp-action="Index"
                                   asp-route-lang="@currentLang"
                                   asp-route-voiceLang="@currentVoiceLang">
                                @T("Khám phá", "Explore")
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(controller == "FoodStalls" ? "active" : "")"
                                   asp-controller="FoodStalls"
                                   asp-action="Index"
                                   asp-route-lang="@currentLang"
                                   asp-route-voiceLang="@currentVoiceLang">
                                @T("Danh sách quán", "Food stalls")
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(controller == "Tours" ? "active" : "")"
                                   asp-controller="Tours"
                                   asp-action="Index"
                                   asp-route-lang="@currentLang"
                                   asp-route-voiceLang="@currentVoiceLang">
                                Tour
                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <button class="language-menu-button dropdown-toggle"
                                    type="button"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false">
                                <span class="language-flag">@(currentLang == "en" ? "🇬🇧" : "🇻🇳")</span>
                                <span>@(currentLang == "en" ? "English" : "Tiếng Việt")</span>
                            </button>

                            <ul class="dropdown-menu dropdown-menu-end language-dropdown">
                                <li>
                                    <a class="dropdown-item language-dropdown-item @(currentLang == "vi" ? "active" : "")"
                                           href="@BuildLanguageUrl("vi")">
                                        <span class="language-flag">🇻🇳</span>
                                        <span>Tiếng Việt</span>
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item language-dropdown-item @(currentLang == "en" ? "active" : "")"
                                           href="@BuildLanguageUrl("en")">
                                        <span class="language-flag">🇬🇧</span>
                                        <span>English</span>
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container app-page">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer">
        <div class="container">
            &copy; 2026 - Audio Guide - <a asp-controller="Home"
                                       asp-action="Privacy"
                                       asp-route-lang="@currentLang"
                                       asp-route-voiceLang="@currentVoiceLang">
            Privacy
        </a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>