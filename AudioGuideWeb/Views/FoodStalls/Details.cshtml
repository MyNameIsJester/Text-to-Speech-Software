@model AudioGuideWeb.Models.FoodStallViewModel

@{
    ViewData["Title"] = Model.Name ?? "Chi tiết quán";
}

<h2>@Model.Name</h2>

@if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
{
    <img src="@Model.ImageUrl"
         style="width:100%;max-height:300px;object-fit:cover;" />
}

<p><strong>Địa chỉ:</strong> @Model.Address</p>
<p><strong>Món đặc trưng:</strong> @Model.Specialty</p>
<p><strong>Giá:</strong> @Model.PriceRange</p>

<p>@Model.Description</p>

@if (!string.IsNullOrWhiteSpace(Model.MapLink))
{
    <a href="@Model.MapLink" target="_blank" class="btn btn-outline-primary">
        Mở Google Maps
    </a>
}