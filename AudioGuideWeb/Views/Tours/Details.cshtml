@model AudioGuideWeb.Models.TourViewModel

@{
    var currentLanguage = Context.Request.Query["lang"].FirstOrDefault()
        ?? ViewBag.CurrentLanguage as string
        ?? "vi";

    var currentVoiceLang = Context.Request.Query["voiceLang"].FirstOrDefault() ?? currentLanguage;
    var isEnglish = currentLanguage == "en";

    string T(string vi, string en) => isEnglish ? en : vi;

    ViewData["Title"] = T("Chi tiết tour", "Tour details");
    var orderedStops = Model.Stops.OrderBy(x => x.OrderIndex).ToList();

    var ui = new
    {
        pageTitle = T("Chi tiết tour", "Tour details"),
        pageSubtitle = T(
            "Xem trước lộ trình, danh sách điểm dừng và chuẩn bị bắt đầu trải nghiệm tour theo từng chặng.",
            "Preview the route, review the stop list, and get ready to start the step-by-step tour experience."
        ),
        startTour = T("Bắt đầu tour", "Start tour"),
        backToList = T("Quay lại danh sách tour", "Back to tour list"),
        infoTitle = T("Thông tin tour", "Tour information"),
        stopCount = T("điểm dừng", "stops"),
        language = T("Ngôn ngữ", "Language"),
        noDescription = T("Tour này hiện chưa có mô tả chi tiết.", "This tour does not have a detailed description yet."),
        stopList = T("Danh sách điểm dừng", "Stop list"),
        noStops = T("Tour này hiện chưa có điểm dừng hợp lệ.", "This tour does not have valid stops yet."),
        stopFallback = T("Điểm dừng", "Stop"),
        order = T("Thứ tự", "Order"),
        address = T("Địa chỉ", "Address"),
        noAddress = T("Chưa có địa chỉ", "No address available"),
        mapNote = T(
            "Bản đồ này hiển thị trước các điểm dừng của tour theo đúng thứ tự để bạn dễ hình dung lộ trình trước khi bắt đầu.",
            "This map previews the tour stops in the correct order so you can understand the route before starting."
        ),
        popupStop = T("Điểm dừng", "Stop"),
        noName = T("Không có tên", "No name")
    };
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
      crossorigin="" />

<style>
    .tour-details-header {
        margin-bottom: 1.5rem;
    }

    .tour-details-title {
        font-size: 2.15rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.08;
        color: #111827;
        margin-bottom: 0.45rem;
    }

    .tour-details-subtitle {
        color: #6b7280;
        font-size: 1rem;
        line-height: 1.65;
        margin-bottom: 0;
        max-width: 900px;
    }

    .tour-details-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-top: 1rem;
    }

    .summary-card,
    .map-card,
    .stops-card {
        border: 1px solid #e5e7eb;
        border-radius: 1.25rem;
        background: #ffffff;
        box-shadow: 0 18px 40px rgba(17, 24, 39, 0.06);
        overflow: hidden;
    }

    .card-section-title {
        font-size: 1rem;
        font-weight: 800;
        color: #111827;
        margin-bottom: 0.9rem;
    }

    .summary-card-body,
    .stops-card-body {
        padding: 1.25rem;
    }

    .summary-meta {
        display: flex;
        gap: 0.65rem;
        flex-wrap: wrap;
        margin-bottom: 1rem;
    }

    .summary-chip {
        display: inline-flex;
        align-items: center;
        padding: 0.42rem 0.8rem;
        border-radius: 999px;
        background: #f3f4f6;
        color: #374151;
        font-size: 0.84rem;
        font-weight: 800;
    }

    .tour-main-name {
        font-size: 1.35rem;
        font-weight: 800;
        color: #111827;
        line-height: 1.4;
        margin-bottom: 0.55rem;
    }

    .tour-main-description {
        color: #4b5563;
        font-size: 0.96rem;
        line-height: 1.7;
        margin-bottom: 0;
    }

    #tourPreviewMap {
        width: 100%;
        height: 520px;
    }

    .tour-marker {
        width: 32px;
        height: 32px;
        border-radius: 999px;
        background: #111827;
        color: #ffffff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.92rem;
        font-weight: 800;
        border: 2px solid #ffffff;
        box-shadow: 0 10px 18px rgba(17, 24, 39, 0.20);
    }

    .route-note {
        padding: 1rem 1.25rem 1.15rem;
        border-top: 1px solid #e5e7eb;
        color: #6b7280;
        font-size: 0.92rem;
        line-height: 1.6;
    }

    .stop-list {
        display: flex;
        flex-direction: column;
        gap: 0.9rem;
    }

    .stop-item {
        display: flex;
        align-items: flex-start;
        gap: 0.85rem;
        padding-bottom: 0.9rem;
        border-bottom: 1px solid #f1f5f9;
    }

    .stop-item:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }

    .stop-number {
        min-width: 2.2rem;
        height: 2.2rem;
        border-radius: 999px;
        background: #111827;
        color: #ffffff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.88rem;
        font-weight: 800;
        flex-shrink: 0;
    }

    .stop-name {
        font-size: 1rem;
        font-weight: 800;
        color: #111827;
        line-height: 1.4;
        margin-bottom: 0.2rem;
    }

    .stop-meta {
        color: #6b7280;
        font-size: 0.9rem;
        line-height: 1.6;
    }

    .tour-btn-primary,
    .tour-btn-secondary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 42px;
        padding: 0.68rem 1rem;
        border-radius: 0.82rem;
        font-size: 0.92rem;
        font-weight: 800;
        text-decoration: none;
        transition: all 0.18s ease;
    }

    .tour-btn-primary {
        background: #111827;
        color: #ffffff !important;
        border: 1px solid #111827;
    }

    .tour-btn-primary:hover {
        background: #000000;
        color: #ffffff !important;
    }

    .tour-btn-secondary {
        background: #ffffff;
        color: #111827 !important;
        border: 1px solid #d1d5db;
    }

    .tour-btn-secondary:hover {
        background: #f9fafb;
        color: #111827 !important;
        border-color: #9ca3af;
    }

    @@media (max-width: 991.98px) {
        #tourPreviewMap {
            height: 420px;
        }
    }

    @@media (max-width: 575.98px) {
        .tour-details-title {
            font-size: 1.8rem;
        }

        .tour-details-actions {
            flex-direction: column;
        }

        .tour-btn-primary,
        .tour-btn-secondary {
            width: 100%;
        }
    }
</style>

<div class="tour-details-header">
    <h1 class="tour-details-title">@ui.pageTitle</h1>
    <p class="tour-details-subtitle">@ui.pageSubtitle</p>

    <div class="tour-details-actions">
        <a asp-controller="Home"
           asp-action="Index"
           asp-route-lang="@currentLanguage"
           asp-route-voiceLang="@currentVoiceLang"
           asp-route-tourId="@Model.Id"
           asp-route-startTour="true"
           class="tour-btn-primary">
            @ui.startTour
        </a>

        <a asp-controller="Tours"
           asp-action="Index"
           asp-route-lang="@currentLanguage"
           asp-route-voiceLang="@currentVoiceLang"
           class="tour-btn-secondary">
            @ui.backToList
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-5">
        <div class="summary-card mb-4">
            <div class="summary-card-body">
                <div class="card-section-title">@ui.infoTitle</div>

                <div class="summary-meta">
                    <div class="summary-chip">📍 @Model.StopCount @ui.stopCount</div>
                    <div class="summary-chip">@ui.language: @Model.LanguageCode</div>
                </div>

                <div class="tour-main-name">
                    @(string.IsNullOrWhiteSpace(Model.Name) ? $"Tour #{Model.Id}" : Model.Name)
                </div>

                <p class="tour-main-description">
                    @(string.IsNullOrWhiteSpace(Model.Description) ? ui.noDescription : Model.Description)
                </p>
            </div>
        </div>

        <div class="stops-card">
            <div class="stops-card-body">
                <div class="card-section-title">@ui.stopList</div>

                @if (!orderedStops.Any())
                {
                    <div class="text-muted">@ui.noStops</div>
                }
                else
                {
                    <div class="stop-list">
                        @for (int i = 0; i < orderedStops.Count; i++)
                        {
                            var stop = orderedStops[i];

                            <div class="stop-item">
                                <div class="stop-number">@(i + 1)</div>

                                <div>
                                    <div class="stop-name">
                                        @(string.IsNullOrWhiteSpace(stop.Name)
                                            ? $"{ui.stopFallback} #{stop.OrderIndex}"
                                            : stop.Name)
                                    </div>

                                    <div class="stop-meta">
                                        @ui.order: @stop.OrderIndex
                                    </div>

                                    <div class="stop-meta">
                                        @ui.address:
                                        @(string.IsNullOrWhiteSpace(stop.Address)
                                            ? ui.noAddress
                                            : stop.Address)
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-xl-7">
        <div class="map-card">
            <div id="tourPreviewMap"></div>

            <div class="route-note">
                @ui.mapNote
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
            crossorigin=""></script>

    <script>
        const uiText = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ui));

        const stops = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            orderedStops.Select((x, index) => new
            {
                Index = index + 1,
                x.OrderIndex,
                x.Name,
                x.Address,
                x.Latitude,
                x.Longitude
            })
        ));

        const map = L.map("tourPreviewMap");

        L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
            maxZoom: 19,
            attribution: "&copy; OpenStreetMap contributors"
        }).addTo(map);

        let routeLine = null;

        function clearRouteLine() {
            if (routeLine) {
                map.removeLayer(routeLine);
                routeLine = null;
            }
        }

        function drawFallbackPolyline(latLngs) {
            clearRouteLine();

            if (latLngs.length >= 2) {
                routeLine = L.polyline(latLngs, {
                    weight: 4,
                    opacity: 0.85
                }).addTo(map);
            }
        }

        async function drawRoadRoute(stops) {
            const coordinates = stops
                .map(stop => `${stop.Longitude},${stop.Latitude}`)
                .join(";");

            const url = `https://router.project-osrm.org/route/v1/driving/${coordinates}?overview=full&geometries=geojson`;

            try {
                const response = await fetch(url);

                if (!response.ok) {
                    throw new Error(`Routing HTTP ${response.status}`);
                }

                const data = await response.json();

                if (data.code !== "Ok" || !data.routes || !data.routes.length) {
                    throw new Error("No route returned");
                }

                const routeCoords = data.routes[0].geometry.coordinates.map(c => [c[1], c[0]]);

                clearRouteLine();
                routeLine = L.polyline(routeCoords, {
                    weight: 5,
                    opacity: 0.9
                }).addTo(map);

                const bounds = L.latLngBounds(routeCoords);
                map.fitBounds(bounds, { padding: [30, 30] });
            } catch (error) {
                const fallbackLatLngs = stops.map(stop => [stop.Latitude, stop.Longitude]);
                drawFallbackPolyline(fallbackLatLngs);

                if (fallbackLatLngs.length) {
                    const bounds = L.latLngBounds(fallbackLatLngs);
                    map.fitBounds(bounds, { padding: [30, 30] });
                }

                console.warn("Road routing failed, fallback to straight polyline.", error);
            }
        }

        if (!stops || stops.length === 0) {
            map.setView([10.7588, 106.6857], 16);
        } else {
            const latLngs = stops.map(stop => [stop.Latitude, stop.Longitude]);

            stops.forEach(stop => {
                const numberedIcon = L.divIcon({
                    className: "",
                    html: `<div class="tour-marker">${stop.Index}</div>`,
                    iconSize: [32, 32],
                    iconAnchor: [16, 16],
                    popupAnchor: [0, -16]
                });

                L.marker([stop.Latitude, stop.Longitude], { icon: numberedIcon })
                    .bindPopup(`
                        <strong>${uiText.popupStop} ${stop.Index}</strong><br/>
                        ${stop.Name ?? uiText.noName}<br/>
                        ${stop.Address ?? uiText.noAddress}
                    `)
                    .addTo(map);
            });

            const bounds = L.latLngBounds(latLngs);
            map.fitBounds(bounds, { padding: [30, 30] });

            if (stops.length >= 2) {
                drawRoadRoute(stops);
            }
        }

        setTimeout(() => {
            map.invalidateSize();
        }, 300);

        window.addEventListener("resize", () => {
            map.invalidateSize();
        });
    </script>
}