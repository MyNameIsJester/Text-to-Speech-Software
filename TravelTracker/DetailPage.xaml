<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TravelTracker.DetailPage"
             Title="Chi Tiết Hàng Quán Phố Ẩm Thực Vĩnh Khánh ">
    
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15" >

            <Image Source="{Binding ImageUrl}" 
                   HeightRequest="250" 
                   Aspect="AspectFill" />

            <Label Text="{Binding Name}" 
                   FontSize="28" 
                   FontAttributes="Bold"
                   TextColor="#512BD4" />
            
            <HorizontalStackLayout Spacing="5">
                <Label Text="Món đặc sắc:" FontAttributes="Bold" TextColor="OrangeRed" />
                <Label Text="{Binding Specialty}" FontAttributes="Italic" />
            </HorizontalStackLayout>

            <Border Stroke="#E0E0E0" 
                    StrokeShape="RoundRectangle 10" 
                    Padding="15">
                <Label Text="{Binding Description}" 
                       FontSize="16" 
                       TextColor="DimGray"
                       CharacterSpacing="0.2"
                       HorizontalTextAlignment="Justify"
                       LineBreakMode="WordWrap"
                       LineHeight="1.4"/>
            </Border>

            <HorizontalStackLayout Spacing="10" 
                                   HorizontalOptions="Center" 
                                   Margin="0,10,0,30" >

                <Button Text="Nghe tiếp" 
                        Clicked="OnListenClicked" 
                        BackgroundColor="Green" 
                        WidthRequest="110" 
                        CornerRadius="15" />

                <Button Text="Dừng" 
                        Clicked="OnStopClicked" 
                        BackgroundColor="Red" 
                        WidthRequest="110" 
                        CornerRadius="15" />

                <Button Text="Làm mới" 
                        Clicked="OnResetClicked" 
                        BackgroundColor="Gray" 
                        WidthRequest="110" 
                        CornerRadius="15" />

            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>