<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TravelTracker.Views.ToursPage"
             Title="Hành trình Khám phá">

    <Grid BackgroundColor="#F5F6F8">
        <ActivityIndicator x:Name="LoadingIndicator" 
                           IsRunning="True" 
                           IsVisible="True"
                           Color="#FF5722" 
                           HorizontalOptions="Center" 
                           VerticalOptions="Center" />

        <CollectionView x:Name="ToursCollectionView"
                        SelectionMode="Single"
                        SelectionChanged="OnTourSelected"
                        IsVisible="False"
                        Margin="15">
            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Border Margin="0,0,0,15" Padding="0" Stroke="Transparent" StrokeThickness="0" BackgroundColor="White">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>

                        <Border.Shadow>
                            <Shadow Brush="#333333" Offset="0,2" Radius="6" Opacity="0.1" />
                        </Border.Shadow>

                        <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto, Auto" Padding="15">

                            <Border Grid.RowSpan="3" Grid.Column="0" WidthRequest="70" HeightRequest="70" Padding="0" Margin="0,0,15,0" BackgroundColor="#FFF0E6" Stroke="Transparent" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10" />
                                </Border.StrokeShape>

                                <Image Source="tour_icon.png" Aspect="AspectFill" HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="40" HeightRequest="40"/>
                            </Border>

                            <Label Grid.Row="0" Grid.Column="1" Text="{Binding Name}" FontAttributes="Bold" FontSize="18" TextColor="#333333" Margin="0,0,0,5" />

                            <Label Grid.Row="1" Grid.Column="1" Text="{Binding Description}" FontSize="14" TextColor="#666666" MaxLines="2" LineBreakMode="TailTruncation" Margin="0,0,0,10" />

                            <HorizontalStackLayout Grid.Row="2" Grid.Column="1" Spacing="5">
                                <Label Text="📍" FontSize="12"/>
                                <Label Text="{Binding TotalStops, StringFormat='{0} điểm dừng'}" FontSize="12" TextColor="#FF5722" FontAttributes="Bold"/>
                            </HorizontalStackLayout>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>