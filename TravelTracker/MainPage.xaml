<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:TravelTracker.Services"
             x:Class="TravelTracker.MainPage"
             Title="Thuyết Minh Khu Ẩm Thực Q.4"
             BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#121212}">

    <Shell.TitleView>
        <Grid ColumnDefinitions="*, Auto" Padding="10,0,20,0">
            <Label Grid.Column="0" 
                   Text="Thuyết Minh Q.4" 
                   TextColor="{AppThemeBinding Light=#512BD4, Dark=#B49BFF}" 
                   FontAttributes="Bold" 
                   FontSize="18" 
                   VerticalOptions="Center" />

            <Picker Grid.Column="1" 
                    ItemsSource="{Binding Languages}" 
                    ItemDisplayBinding="{Binding DisplayName}"
                    SelectedItem="{Binding SelectedLanguage}"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                    TitleColor="{AppThemeBinding Light=Black, Dark=White}"
                    Title="🌍 Ngôn ngữ"
                    VerticalOptions="Center"
                    WidthRequest="140" />
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="Auto, *">

        <VerticalStackLayout Grid.Row="0" Padding="25,30,25,20" Spacing="5" 
                             BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
            <Label Text="PHỐ VĨNH KHÁNH" 
                   FontSize="14"    
                   TextColor="{AppThemeBinding Light=#512BD4, Dark=#B49BFF}" 
                   FontAttributes="Bold" 
                   CharacterSpacing="2" />

            <Label Text="{Binding UIGreeting, Source={x:Static services:LanguageService.Instance}}"
                   FontSize="32" 
                   FontAttributes="Bold" 
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" 
                        ItemsSource="{Binding Stalls}"
                        SelectionMode="Single"
                        SelectionChanged="OnStallSelected">

            <CollectionView.Header>
                <VerticalStackLayout Padding="20,10,20,20" Spacing="15">

                    <Border Padding="20" 
                            Background="{AppThemeBinding Light=#F0EDFF, Dark=#2A2540}" 
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 20">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="{Binding UIIntroHeading, Source={x:Static services:LanguageService.Instance}}" 
                                   FontSize="13" 
                                   FontAttributes="Bold" 
                                   TextColor="{AppThemeBinding Light=#512BD4, Dark=#B49BFF}" />

                            <Label Text="{Binding SelectedLanguage.IntroText}" 
                                   FontSize="15" 
                                   TextColor="{AppThemeBinding Light=#444444, Dark=#DDDDDD}"
                                   LineHeight="1.4"
                                   HorizontalTextAlignment="Justify" />

                            <VerticalStackLayout Spacing="5">
                                <ProgressBar x:Name="introProgressBar"
                                             Progress="0"
                                             ProgressColor="{AppThemeBinding Light=#512BD4, Dark=#B49BFF}"
                                             HeightRequest="4" />

                                <Label x:Name="lblProgressPercent" 
                                       Text="0%" 
                                       FontSize="11" 
                                       TextColor="Gray" 
                                       HorizontalOptions="End" />
                            </VerticalStackLayout>

                            <Button x:Name="btnToggleIntro"
                                    Text="{Binding UIPlayIntroBtn, Source={x:Static services:LanguageService.Instance}}" 
                                    Clicked="OnToggleStreetIntroClicked"
                                    BackgroundColor="{AppThemeBinding Light=#512BD4, Dark=#7E57C2}" 
                                    TextColor="White"
                                    CornerRadius="20"
                                    HeightRequest="45"
                                    Padding="20,0"
                                    HorizontalOptions="Start" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Padding="0" 
                            Margin="0,15,0,0" 
                            Stroke="Transparent" 
                            StrokeShape="RoundRectangle 15">

                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.1" />
                        </Border.Shadow>

                        <SearchBar x:Name="searchBar" 
                                   Placeholder="{Binding UISearchPlaceholder, Source={x:Static services:LanguageService.Instance}}" 
                                   TextChanged="OnSearchBarTextChanged"
                                   BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    </Border>

                    <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Margin="0,15,0,10">
                        <HorizontalStackLayout Spacing="10">
                            <Button Text="🌟 Tất cả" Clicked="OnCategoryClicked" CornerRadius="20" BackgroundColor="#512BD4" TextColor="White" HeightRequest="40"/>
                            <Button Text="🐌 Ốc" Clicked="OnCategoryClicked" CornerRadius="20" BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#333333}" TextColor="{AppThemeBinding Light=Black, Dark=White}" HeightRequest="40"/>
                            <Button Text="🔥 Nướng" Clicked="OnCategoryClicked" CornerRadius="20" BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#333333}" TextColor="{AppThemeBinding Light=Black, Dark=White}" HeightRequest="40"/>
                            <Button Text="🍲 Lẩu" Clicked="OnCategoryClicked" CornerRadius="20" BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#333333}" TextColor="{AppThemeBinding Light=Black, Dark=White}" HeightRequest="40"/>
                        </HorizontalStackLayout>
                    </ScrollView>

                    <Label Text="{Binding UIListHeading, Source={x:Static services:LanguageService.Instance}}" 
                           FontSize="14" 
                           FontAttributes="Bold" 
                           TextColor="Gray" 
                           Margin="5,10,0,0"/>
                </VerticalStackLayout>
            </CollectionView.Header>

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="20" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="20,0">
                        <Border Padding="0" 
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 20">
                            <Border.Shadow>
                                <Shadow Brush="Black"
                                        Offset="0,5"
                                        Radius="10"
                                        Opacity="0.1" />
                            </Border.Shadow>

                            <Grid RowDefinitions="200, Auto">
                                <Image Grid.Row="0" 
                                       Source="{Binding ImageUrl}"  
                                       Aspect="AspectFill" 
                                       HeightRequest="200" />

                                <BoxView Grid.Row="0" VerticalOptions="End" HeightRequest="60">
                                    <BoxView.Background>
                                        <LinearGradientBrush EndPoint="0,1">
                                            <GradientStop Color="Transparent" Offset="0" />
                                            <GradientStop Color="#CC000000" Offset="1" />
                                        </LinearGradientBrush>
                                    </BoxView.Background>
                                </BoxView>

                                <Label Grid.Row="0" 
                                       Text="{Binding Address}" 
                                       TextColor="White" 
                                       Margin="15" 
                                       VerticalOptions="End" 
                                       FontSize="13" />

                                <VerticalStackLayout Grid.Row="1" Padding="20" Spacing="8" 
                                                     BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">

                                    <Grid ColumnDefinitions="*, Auto, Auto">
                                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                                            <Label Text="{Binding Name}" 
                                                   FontSize="22" 
                                                   TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                                   FontAttributes="Bold" />

                                            <Label Text="{Binding DistanceText}" 
                                                   FontSize="13" 
                                                   TextColor="{AppThemeBinding Light=#E03131, Dark=#FF6B6B}" 
                                                   FontAttributes="Bold" />
                                        </VerticalStackLayout>

                                        <Button Grid.Column="1"
                                                Text="{Binding FavoriteButtonText}"
                                                BackgroundColor="{Binding FavoriteButtonColor}"
                                                FontSize="24"
                                                Padding="0"
                                                Margin="0,0,15,0"
                                                Clicked="OnFavoriteClicked"
                                                CommandParameter="{Binding .}" />

                                        <ImageButton Grid.Column="2"
                                                     Source="ggmap.png"
                                                     BackgroundColor="Transparent"
                                                     HeightRequest="40"
                                                     WidthRequest="40"
                                                     CornerRadius="20"
                                                     Padding="0"
                                                     Clicked="OnGoToMapClicked"
                                                     CommandParameter="{Binding .}" />
                                    </Grid>

                                    <HorizontalStackLayout Spacing="5">
                                        <Label Text="{Binding UISpecialty, Source={x:Static services:LanguageService.Instance}}" FontAttributes="Bold" FontSize="14" 
                                               TextColor="{AppThemeBinding Light=#512BD4, Dark=#B49BFF}" />
                                        <Label Text="{Binding Specialty}" FontSize="14" 
                                               TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                    </HorizontalStackLayout>

                                    <Label Text="{Binding Description}" 
                                           FontSize="14" 
                                           TextColor="{AppThemeBinding Light=DimGray, Dark=#AAAAAA}" 
                                           MaxLines="2" 
                                           LineBreakMode="TailTruncation" />

                                    <Label Text="{Binding UIDetailBtn, Source={x:Static services:LanguageService.Instance}}" 
                                           TextColor="{AppThemeBinding Light=#512BD4, Dark=#B49BFF}" 
                                           FontSize="13" 
                                           FontAttributes="Bold" 
                                           Margin="0,10,0,0" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>
    </Grid>
</ContentPage>