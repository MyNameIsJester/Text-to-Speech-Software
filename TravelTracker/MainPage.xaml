<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TravelTracker.MainPage"
             Title="Thuyết Minh Ẩm Thực Q.4"
             BackgroundColor="#F8F9FA">

    <Shell.TitleView>
        <Grid ColumnDefinitions="*, Auto" Padding="10,0,20,0">
            <Label Grid.Column="0" 
                   Text="Thuyết Minh Q.4" 
                   TextColor="White" 
                   FontAttributes="Bold" 
                   FontSize="18" 
                   VerticalOptions="Center" />

            <Picker Grid.Column="1" 
                    ItemsSource="{Binding Languages}" 
                    ItemDisplayBinding="{Binding DisplayName}"
                    SelectedItem="{Binding SelectedLanguage}"
                    TextColor="White"
                    TitleColor="White"
                    Title="🌍 Ngôn ngữ"
                    VerticalOptions="Center"
                    WidthRequest="140" />
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="Auto, *">

        <VerticalStackLayout Grid.Row="0" Padding="25,30,25,20" Spacing="5" BackgroundColor="White">
            <Label Text="PHỐ VĨNH KHÁNH" 
                   FontSize="14" 
                   TextColor="#512BD4" 
                   FontAttributes="Bold" 
                   CharacterSpacing="2" />
            <Label Text="Ăn gì hôm nay?" 
                   FontSize="32" 
                   FontAttributes="Bold" 
                   TextColor="Black" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" 
                        ItemsSource="{Binding Stalls}"
                        SelectionMode="Single"
                        SelectionChanged="OnStallSelected">

            <CollectionView.Header>
                <VerticalStackLayout Padding="20,10,20,20" Spacing="15">
                    <Border Padding="20" 
                            Background="#F0EDFF" 
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 20">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="GIỚI THIỆU TỔNG QUAN" 
                                   FontSize="13" 
                                   FontAttributes="Bold" 
                                   TextColor="#512BD4" />

                            <Label Text="{Binding SelectedLanguage.IntroText}" 
                                   FontSize="15" 
                                   TextColor="#444444"
                                   LineHeight="1.4"
                                   HorizontalTextAlignment="Justify" />
                            
                            <VerticalStackLayout Spacing="5">
                                <ProgressBar x:Name="introProgressBar"
                                             Progress="0"
                                             ProgressColor="#512BD4"
                                             HeightRequest="4" />

                                <Label x:Name="lblProgressPercent" 
                                       Text="0%" 
                                       FontSize="11" 
                                       TextColor="Gray" 
                                       HorizontalOptions="End" />
                            </VerticalStackLayout>

                            <Button x:Name="btnToggleIntro"
                                    Text="🎧 Nghe giới thiệu" 
                                    Clicked="OnToggleStreetIntroClicked"
                                    BackgroundColor="#512BD4" 
                                    TextColor="White"
                                    CornerRadius="20"
                                    HeightRequest="45"
                                    Padding="20,0"
                                    HorizontalOptions="Start" />
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="DANH SÁCH HÀNG QUÁN" 
                           FontSize="14" 
                           FontAttributes="Bold" 
                           TextColor="Gray" 
                           Margin="5,10,0,0"/>
                </VerticalStackLayout>
            </CollectionView.Header>

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="20" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="20,0">
                        <Border Padding="0" 
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 20">
                            <Border.Shadow>
                                <Shadow Brush="Black"
                                        Offset="0,5"
                                        Radius="10"
                                        Opacity="0.1" />
                            </Border.Shadow>

                            <Grid RowDefinitions="200, Auto">
                                <Image Grid.Row="0" 
                                       Source="{Binding ImageUrl}" 
                                       Aspect="AspectFill" 
                                       HeightRequest="200" />

                                <BoxView Grid.Row="0" VerticalOptions="End" HeightRequest="60">
                                    <BoxView.Background>
                                        <LinearGradientBrush EndPoint="0,1">
                                            <GradientStop Color="Transparent" Offset="0" />
                                            <GradientStop Color="#CC000000" Offset="1" />
                                        </LinearGradientBrush>
                                    </BoxView.Background>
                                </BoxView>

                                <Label Grid.Row="0" 
                                       Text="{Binding Address}" 
                                       TextColor="White" 
                                       Margin="15" 
                                       VerticalOptions="End" 
                                       FontSize="13" />

                                <VerticalStackLayout Grid.Row="1" Padding="20" Spacing="8" BackgroundColor="White">

                                    <Grid ColumnDefinitions="*, Auto">
                                        <Label Grid.Column="0"
                                            Text="{Binding Name}" 
                                            FontSize="22" 
                                            FontAttributes="Bold"
                                            VerticalOptions="Center" />

                                        <ImageButton Grid.Column="1"
                                                     Source="ggmap.png"
                                                     BackgroundColor="Transparent"
                                                     HeightRequest="40"
                                                     WidthRequest="40"
                                                     CornerRadius="20"
                                                     Padding="0"
                                                     Clicked="OnGoToMapClicked"
                                                     CommandParameter="{Binding .}" />
                                    </Grid>

                                    <HorizontalStackLayout Spacing="5">
                                        <Label Text="🍴 Đặc sản:" FontAttributes="Bold" FontSize="14" TextColor="#512BD4" />
                                        <Label Text="{Binding Specialty}" FontSize="14" TextColor="Black" />
                                    </HorizontalStackLayout>

                                    <Label Text="{Binding Description}" 
                                           FontSize="14" 
                                           TextColor="DimGray" 
                                           MaxLines="2" 
                                           LineBreakMode="TailTruncation" />

                                    <Label Text="Xem chi tiết &amp; Nghe thuyết minh →" 
                                           TextColor="#512BD4" 
                                           FontSize="13" 
                                           FontAttributes="Bold" 
                                           Margin="0,10,0,0" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>
    </Grid>
</ContentPage>