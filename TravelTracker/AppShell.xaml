<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TravelTracker.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:TravelTracker"
    Title="TravelTracker">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />
    <TabBar>
        <ShellContent Title="Home" ContentTemplate="{DataTemplate local:MainPage}" Route="MainPage" />
        <ShellContent Title="Map" ContentTemplate="{DataTemplate local:MapPage}" Route="MapPage" />
        <ShellContent Title="Detail" ContentTemplate="{DataTemplate local:DetailPage}" Route="DetailPage" />
    </TabBar>
</Shell>
